    // --- NODE LOGIC ---
    async function handleRoomNodeClick(e) {
        const input = prompt(
            "Enter Room IDs (comma separated, e.g. '201, 202'):",
        );
        if (!input) return;

        const rooms = input
            .split(",")
            .map((s) => s.trim())
            .filter((s) => s.length > 0);
        if (rooms.length === 0) return;

        const uid = crypto.randomUUID();

        const node = {
            uid: uid,
            rooms: rooms,
            lat: e.latlng.lat,
            lng: e.latlng.lng,
            type: "room",
            floor: currentFloor
        };

        collectedNodes.push(node);
        addMarker(node);
        updateUI();
        
        // Rebuild graph if it exists
        if (navigationGraph) {
            await initializeNavigation();
        }
    }

