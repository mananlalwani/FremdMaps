    function handleFindRoute() {
        const startInput = document.getElementById('start-input') as HTMLInputElement;
        const endInput = document.getElementById('end-input') as HTMLInputElement;
        
        if (!startInput || !endInput) return;
        
        const startRoom = startInput.value.trim();
        const endRoom = endInput.value.trim();
        
        if (!startRoom || !endRoom) {
            showStatusMessage('Please enter both start and destination', 'warning');
            return;
        }
        
        if (!navigationGraph) {
            showStatusMessage('Navigation system is still loading. Please wait a moment.', 'warning');
            return;
        }
        
        // Show loading state
        const findRouteBtn = document.getElementById('find-route-btn');
        const originalBtnText = findRouteBtn?.textContent || '';
        if (findRouteBtn) {
            findRouteBtn.textContent = 'Calculating...';
            (findRouteBtn as HTMLButtonElement).disabled = true;
        }
        
        // Use setTimeout to let UI update before heavy computation
        setTimeout(() => {
            try {
                // Try to use selected nodes from search dropdown first, fallback to text search
                // Always search allNodesAllFloors (not collectedNodes) so cross-floor rooms are found
                let startNode = selectedStartNode || findNodeByRoom(startRoom, allNodesAllFloors) || findExactMatch(startRoom, allNodesAllFloors);
                let endNode = selectedEndNode || findNodeByRoom(endRoom, allNodesAllFloors) || findExactMatch(endRoom, allNodesAllFloors);
                
                // If still not found, try fuzzy search across all floors
                if (!startNode) {
                    const results = searchNodes(startRoom, allNodesAllFloors, { limit: 1 });
                    if (results.length > 0 && results[0].score < 0.6) {
                        startNode = results[0].node;
                        searchLogger.log(`Using fuzzy match for start: ${startRoom} → ${startNode.rooms[0]}`);
                    }
                }
                
                if (!endNode) {
                    const results = searchNodes(endRoom, allNodesAllFloors, { limit: 1 });
                    if (results.length > 0 && results[0].score < 0.6) {
                        endNode = results[0].node;
                        searchLogger.log(`Using fuzzy match for end: ${endRoom} → ${endNode.rooms[0]}`);
                    }
                }
                
                if (!startNode) {
                    showStatusMessage(`Starting location "${startRoom}" not found. Try a different search.`, 'error');
                    return;
                }
                
                if (!endNode) {
                    showStatusMessage(`Destination "${endRoom}" not found. Try a different search.`, 'error');
                    return;
                }
                
                // Run A* pathfinding across all floors
                routeLogger.log(`Finding path from ${startRoom} to ${endRoom}...`);
                console.log('[findRoute] startNode:', { uid: startNode.uid, rooms: startNode.rooms, floor: (startNode as any).floor });
                console.log('[findRoute] endNode:', { uid: endNode.uid, rooms: endNode.rooms, floor: (endNode as any).floor });
                console.log('[findRoute] allNodesAllFloors count:', allNodesAllFloors.length);
                console.log('[findRoute] allNodesAllFloors sample floors:', allNodesAllFloors.slice(0,3).map((n:any) => n.floor));
                const result = findPath(startNode.uid, endNode.uid, allNodesAllFloors, navigationGraph);
                
                if (!result.found) {
                    showStatusMessage('No path found between these locations. They may be on different floors or blocked by walls.', 'error');
                    return;
                }
                
                // Save to recent searches
                addRecentSearch(startRoom, endRoom);
                updateRecentSearchesUI();
                
                routeLogger.log('Path found:', result);
                
                // Display route
                displayRoute(result.path, result.distance);
            } finally {
                // Restore button state
                if (findRouteBtn) {
                    findRouteBtn.textContent = originalBtnText;
                    (findRouteBtn as HTMLButtonElement).disabled = false;
                }
            }
        }, 10);
    }
    
    // Helper function for user-friendly status messages
    function showStatusMessage(message: string, type: 'info' | 'warning' | 'error' = 'info') {
        const routeStatus = document.getElementById('route-status');
        if (routeStatus) {
            const colors = {
                info: 'var(--amber-400)',
                warning: '#ffca28',
                error: '#ff6b6b'
            };
            routeStatus.style.color = colors[type];
            routeStatus.textContent = message;
            
            // Auto-clear after timeout for non-errors
            if (type !== 'error') {
                setTimeout(() => {
                    if (routeStatus.textContent === message) {
                        routeStatus.textContent = '';
                    }
                }, UI_CONFIG.STATUS_MESSAGE_TIMEOUT_MS);
            }
        } else {
            // Fallback to alert if status element not found
            alert(message);
        }
    }

    function displayRoute(path, totalDistance) {
        // Clear previous route
        clearRoute();
        
        // Store full path for multi-floor navigation
        currentRouteFullPath = path;
        
        // DEBUG: inspect floor tags on path nodes
        console.log('[displayRoute] path length:', path.length);
        console.log('[displayRoute] path floors:', path.map(n => n.floor));
        console.log('[displayRoute] path nodes:', path.map(n => ({ rooms: n.rooms, floor: n.floor, type: n.type })));
        
        // Check if route crosses floors
        const floors = [...new Set(path.map(n => n.floor).filter(f => f))];
        const isMultiFloor = floors.length > 1;
        console.log('[displayRoute] unique floors:', floors, '| isMultiFloor:', isMultiFloor);
        
        if (isMultiFloor) {
            routeLogger.log(`Multi-floor route detected: ${floors.join(', ')}`);
            
            // Switch to the starting floor
            const startFloor = path[0].floor;
            if (startFloor && startFloor !== currentFloor) {
                switchFloor(startFloor);
                // Wait a moment for the floor to load, then draw the route
                setTimeout(() => {
                    redrawRouteForCurrentFloor();
                }, 100);
                return;
            }
        }
        
        // Draw route for current floor
        redrawRouteForCurrentFloor();
        
        // Update UI - show detailed route status
        const routeStatus = document.getElementById('route-status');
        const emptyState = document.getElementById('empty-state');
        const statusDetails = document.getElementById('route-status-details');
        
        if (routeStatus) routeStatus.style.display = 'block';
        if (emptyState) emptyState.style.display = 'none';
        
        // Update status text
        if (statusDetails) {
            if (isMultiFloor) {
                const floorCount = floors.length;
                statusDetails.textContent = `${floorCount} floors • Follow the amber path`;
            } else {
                statusDetails.textContent = 'Follow the amber path on the map';
            }
        }
    }
    
    function redrawRouteForCurrentFloor() {
        // Clear existing route display (but keep currentRouteFullPath)
        if (currentRoute) {
            map.removeLayer(currentRoute);
            currentRoute = null;
        }
        
        // Properly clear all route markers including outline layers
        routeMarkers.forEach(m => {
            if (m.__isOutline) {
                map.removeLayer(m.layer);
            } else {
                map.removeLayer(m);
            }
        });
        routeMarkers = [];
        
        if (currentRouteFullPath.length === 0) {
            // Hide multi-floor banner when no route
            const banner = document.getElementById('multi-floor-banner');
            if (banner) banner.style.display = 'none';
            return;
        }
        
        const path = currentRouteFullPath;
        
        // Check if route spans multiple floors
        const floorsInRoute = [...new Set(path.map(n => n.floor).filter(f => f))];
        const isMultiFloor = floorsInRoute.length > 1;
        
        // Show/hide multi-floor banner
        const banner = document.getElementById('multi-floor-banner');
        const bannerFloor = document.getElementById('banner-floor');
        const bannerSwitchBtn = document.getElementById('banner-switch-btn');
        
        // Only show banner if the destination is on a different floor
        // (if destination is already on current floor, no need to switch)
        const destinationFloor = path[path.length - 1].floor;
        const needsFloorSwitch = isMultiFloor && destinationFloor !== currentFloor;
        
        if (banner && needsFloorSwitch) {
            // Find the other floor(s) in the route
            const otherFloors = floorsInRoute.filter(f => f !== currentFloor);
            
            if (otherFloors.length > 0) {
                if (bannerFloor) bannerFloor.textContent = otherFloors[0];
                banner.style.display = 'flex';
                
                // Add click handler to switch floors
                if (bannerSwitchBtn) {
                    bannerSwitchBtn.onclick = () => switchFloor(otherFloors[0]);
                }
            } else {
                banner.style.display = 'none';
            }
        } else if (banner) {
            banner.style.display = 'none';
        }
        
        // Filter path to only nodes on current floor
        const nodesOnCurrentFloor = path.filter(n => n.floor === currentFloor);
        
        routeLogger.log(`Filtering route: ${path.length} total nodes, ${nodesOnCurrentFloor.length} on floor ${currentFloor}`);
        
        if (nodesOnCurrentFloor.length === 0) {
            routeLogger.warn(`No nodes on floor ${currentFloor} in this route`);
            return;
        }
        
        // Simplify path for visualization (removes unnecessary waypoints)
        const simplifiedPath = simplifyPath(nodesOnCurrentFloor, MAP_CONFIG.PATH_SIMPLIFICATION_ANGLE);
        routeLogger.log('Simplified path length:', simplifiedPath.length)
        
        // Draw path with outline for better visibility (two polylines)
        const coordinates = simplifiedPath.map(n => [n.lat, n.lng]);
        
        // First layer: dark outline
        const routeOutline = L.polyline(coordinates, {
            color: '#000000',
            weight: 10,
            opacity: 0.5,
            lineCap: 'round',
            lineJoin: 'round',
        }).addTo(map);
        
        // Second layer: bright path
        currentRoute = L.polyline(coordinates, {
            color: UI_CONFIG.ROUTE_PATH_COLOR,
            weight: 6,
            opacity: 1,
            lineCap: 'round',
            lineJoin: 'round',
        }).addTo(map);
        
        // Store outline for cleanup
        routeMarkers.push({ __isOutline: true, layer: routeOutline } as any);
        
        // Add start marker (if start is on this floor)
        const startNode = path[0];
        if (startNode.floor === currentFloor) {
            const startIcon = L.divIcon({
                className: 'route-marker start',
                html: `<div style="background: #4CAF50; color: white; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 16px; font-family: 'JetBrains Mono', monospace; border: 3px solid white; box-shadow: 0 2px 8px rgba(0,0,0,0.3)">A</div>`,
                iconSize: [36, 36],
                iconAnchor: [18, 18]
            });
            
            const startMarker = L.marker([startNode.lat, startNode.lng], { icon: startIcon }).addTo(map);
            routeMarkers.push(startMarker);
        }
        
        // Add end marker (if end is on this floor)
        const endNode = path[path.length - 1];
        if (endNode.floor === currentFloor) {
            const endIcon = L.divIcon({
                className: 'route-marker end',
                html: `<div style="background: #f44336; color: white; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 16px; font-family: 'JetBrains Mono', monospace; border: 3px solid white; box-shadow: 0 2px 8px rgba(0,0,0,0.3)">B</div>`,
                iconSize: [36, 36],
                iconAnchor: [18, 18]
            });
            
            const endMarker = L.marker([endNode.lat, endNode.lng], { icon: endIcon }).addTo(map);
            routeMarkers.push(endMarker);
        }
        
        // Add stairway markers for floor transitions
        for (let i = 0; i < path.length; i++) {
            const node = path[i];
            if (node.type === 'stairway' && node.floor === currentFloor) {
                const stairIcon = L.divIcon({
                    className: 'route-marker stairway',
                    html: '<div style="background: #9C27B0; color: white; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; border: 2px solid white; box-shadow: 0 0 12px rgba(156,39,176,0.5)">🪜</div>',
                    iconSize: [28, 28],
                    iconAnchor: [14, 14]
                });
                
                const stairMarker = L.marker([node.lat, node.lng], { icon: stairIcon }).addTo(map);
                routeMarkers.push(stairMarker);
            }
        }
        
        // Fit map to route (only the visible part on this floor)
        if (currentRoute) {
            map.fitBounds(currentRoute.getBounds(), { padding: [100, 100] });
        }
    }

    function clearRoute() {
        // Remove route polyline
        if (currentRoute) {
            map.removeLayer(currentRoute);
            currentRoute = null;
        }
        
        // Clear stored route path
        currentRouteFullPath = [];
        
        // Remove route markers and outline layers
        routeMarkers.forEach(m => {
            if (m.__isOutline) {
                map.removeLayer(m.layer);
            } else {
                map.removeLayer(m);
            }
        });
        routeMarkers = [];
        
        // Clear UI
        const routeStatus = document.getElementById('route-status');
        const emptyState = document.getElementById('empty-state');
        const startInput = document.getElementById('start-input') as HTMLInputElement;
        const endInput = document.getElementById('end-input') as HTMLInputElement;
        
        if (routeStatus) routeStatus.style.display = 'none';
        if (emptyState) emptyState.style.display = 'block';
        if (startInput) startInput.value = '';
        if (endInput) endInput.value = '';
        
        // Reset selected nodes
        selectedStartNode = null;
        selectedEndNode = null;
    }

    function handleFindNearestBathroom() {
        const startInput = document.getElementById('start-input') as HTMLInputElement;
        
        if (!startInput) return;
        
        const startRoom = startInput.value.trim();
        
        if (!startRoom) {
            alert('Please enter your starting location first');
            return;
        }
        
        // Show loading state
        const bathroomBtn = document.getElementById('find-bathroom-btn');
        const originalBtnText = bathroomBtn?.textContent || '';
        if (bathroomBtn) {
            bathroomBtn.textContent = 'Finding...';
            (bathroomBtn as HTMLButtonElement).disabled = true;
        }
        
        // Use setTimeout to let UI update
        setTimeout(() => {
            try {
                // Find starting node
                const startNode = findNodeByRoom(startRoom, allNodesAllFloors);
                
                if (!startNode) {
                    alert(`Room "${startRoom}" not found`);
                    return;
                }
                
                // Check navigation graph is ready
                if (!navigationGraph) {
                    alert('Navigation system not ready. Please wait...');
                    return;
                }
                
                // Find nearest bathroom across all floors using actual pathfinding distance
                const bathroom = findNearestBathroom(startNode, allNodesAllFloors, navigationGraph);
                
                if (!bathroom) {
                    alert('No bathrooms found');
                    return;
                }
                
                routeLogger.log('Nearest bathroom found:', bathroom);
                
                // Run pathfinding across all floors
                routeLogger.log(`Finding path from ${startRoom} to ${bathroom.rooms[0]}...`);
                const result = findPath(startNode.uid, bathroom.uid, allNodesAllFloors, navigationGraph);
                
                if (!result.found) {
                    alert('Could not find a path to the nearest bathroom. It may be blocked by walls.');
                    return;
                }
                
                routeLogger.log('Path to bathroom found:', result);
                
                // Display the route
                displayRoute(result.path, result.distance);
            } finally {
                // Restore button state
                if (bathroomBtn) {
                    bathroomBtn.textContent = originalBtnText;
                    (bathroomBtn as HTMLButtonElement).disabled = false;
                }
            }
        }, 10);
    }


