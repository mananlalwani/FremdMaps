---
import '../styles/map.css'
---

<main id="map-content">
  <div
    id="map"
    role="region"
    aria-label="School map"
    aria-describedby="map-instructions"
    tabindex="0"
  >
  </div>
  <p id="map-instructions" class="visually-hidden">
    Interactive school map. Use the From and To fields to plan a route; turn-by-turn directions
    appear in the navigation panel.
  </p>

  <!-- Floor Switcher UI -->
  <div id="floor-switcher">
    <button class="floor-btn active" data-floor="2" aria-current="true">Floor 2</button>
    <button class="floor-btn" data-floor="1">Floor 1</button>
  </div>

  <!-- Multi-Floor Route Banner -->
  <div id="multi-floor-banner" style="display: none;">
    <span id="banner-text">Route continues on another floor</span>
    <button id="banner-switch-btn" class="floor-switch-hint">
      Switch to Floor <span id="banner-floor"></span> →
    </button>
  </div>
</main>

<script>
  import 'leaflet/dist/leaflet.css'
  import L from 'leaflet'
  import type { Graph } from '../utils/types'
  import { MAP_CONFIG, UI_CONFIG } from '../utils/constants'
  import { logger } from '../utils/logger'

  import { invalidateSearchCache } from '../utils/search'

  // Map modules
  import { state } from '../map/map-state'
  import { updateFavoritesUI } from '../map/favorites-ui'
  import { createGraphController } from '../map/graph-controller'
  import { cancelPendingDataLoad, initMap as _initMap, switchFloor } from '../map/map-init'
  import { setupPanelBehavior } from '../map/panel-behavior'
  import { setupRouteActions } from '../map/route-actions'
  import { setupScheduleModal } from '../map/schedule-ui'
  import {
    setupSearchUI,
    updateRecentSearchesUI as refreshRecentSearchesUI,
  } from '../map/search-ui'
  import {
    setRouteDisplayCallbacks,
    redrawRouteForCurrentFloor,
    clearRoute,
  } from '../map/route-display'
  const urlParams = new URLSearchParams(window.location.search)
  // `NODE_ENV=production` can be inherited by a local `astro dev` process,
  // which makes Vite's `DEV` flag false even though its mode remains
  // development. Treat the development server mode as local development too.
  const isDevelopmentServer = import.meta.env.DEV || import.meta.env.MODE === 'development'
  const isLocalPreview = ['localhost', '127.0.0.1', '::1', '[::1]'].includes(
    window.location.hostname
  )

  // ========== GRAPH STATE ==========

  /** Visibility graph built by initializeNavigation and used by route-action controllers. */
  let _graph: Graph | null = null
  const graphController = createGraphController()
  let _searchEnhancementsInitialized = false
  let cleanupSearchUi: (() => void) | null = null
  let navigationBuildRequestId = 0

  // ========== SAFE DOM HELPERS (XSS Prevention) ==========

  /**
   * Safely create a paragraph element with text
   */
  function createTextParagraph(text: string, style?: string): HTMLParagraphElement {
    const p = document.createElement('p')
    p.textContent = text
    if (style) p.setAttribute('style', style)
    return p
  }

  // ========== NAVIGATION LOGIC ==========

  /**
   * Called by map-init after floor data finishes loading.
   * Builds the client-side visibility graph, invalidates the search cache,
   * initialises the search/recent/favourites UI, clears the empty-state
   * placeholder, and enables the navigation action buttons.
   */
  async function initializeNavigation(): Promise<void> {
    const requestId = ++navigationBuildRequestId
    if (state.allNodesAllFloors.length < 2) {
      logger.warn('Not enough nodes for navigation (need at least 2)')
      return
    }

    const graphCacheKey = `${state.graphDataRevision}:${MAP_CONFIG.MAX_HALLWAY_DISTANCE}`

    const previousGraph = _graph
    const nextGraph = await graphController.ensureGraph(
      state.allNodesAllFloors,
      state.wallObjects,
      state.allTrafficZones,
      graphCacheKey
    )
    // A newer edit/reload may have started another build while this worker
    // request was running. Only the newest graph is allowed to update the UI.
    if (requestId !== navigationBuildRequestId) return
    _graph = nextGraph
    if (_graph !== previousGraph) {
      invalidateSearchCache()
    }

    if (!_searchEnhancementsInitialized) {
      cleanupSearchUi = setupSearchUI(requestRoute).cleanup
      _searchEnhancementsInitialized = true
    } else {
      refreshRecentSearchesUI(requestRoute)
      updateFavoritesUI()
    }

    const emptyState = document.getElementById('empty-state')
    if (emptyState) {
      emptyState.innerHTML = ''
    }

    setNavButtonsDisabled(false)
  }

  /**
   * Enable or disable the three primary navigation action buttons
   * (`#find-route-btn`, `#clear-route-btn`, `#find-bathroom-btn`).
   *
   * Buttons start disabled on page load and are enabled once
   * `initializeNavigation` confirms enough nodes have loaded.
   *
   * @param disabled - `true` to disable (e.g. while loading), `false` to enable
   */
  function setNavButtonsDisabled(disabled: boolean): void {
    const ids = ['find-route-btn', 'clear-route-btn', 'find-bathroom-btn']
    for (const id of ids) {
      const btn = document.getElementById(id) as HTMLButtonElement | null
      if (btn) btn.disabled = disabled
    }
  }

  /**
   * Display a transient status message in the `#route-status-details` element.
   *
   * - `info` / `warning` messages auto-clear after `UI_CONFIG.STATUS_MESSAGE_TIMEOUT_MS`.
   * - `error` messages persist until overwritten.
   * - If route-status UI is missing, logs a warning and returns (no blocking dialogs).
   *
   * @param message - Text to show the user
   * @param type    - Severity level; controls colour and auto-clear behaviour
   */
  function showStatusMessage(message: string, type: 'info' | 'warning' | 'error' = 'info'): void {
    const routeStatus = document.getElementById('route-status')
    const routeStatusDetails = document.getElementById('route-status-details')
    if (!routeStatus || !routeStatusDetails) {
      logger.warn('Status message UI not found; dropping message', { message, type })
      return
    }
    routeStatus.classList.remove('hiding')
    routeStatus.style.display = 'block'

    const colors = {
      info: 'var(--amber-400)',
      warning: '#ffca28',
      error: '#ff6b6b',
    }
    routeStatusDetails.style.color = colors[type]
    routeStatusDetails.textContent = message

    if (type !== 'error') {
      setTimeout(() => {
        if (routeStatusDetails.textContent === message) {
          routeStatusDetails.textContent = ''
        }
      }, UI_CONFIG.STATUS_MESSAGE_TIMEOUT_MS)
    }
  }

  // ========== WIRE UP CALLBACKS ==========

  setRouteDisplayCallbacks({ switchFloor })

  _initMap({
    clearRoute,
    redrawRouteForCurrentFloor,
    initializeNavigation,
    createTextParagraph,
  })

  // Dev tools are lazy-loaded and exposed for local development/preview. A
  // public deployment still requires PUBLIC_ENABLE_DEV=true and ?dev.
  const devToolsEnabled =
    isDevelopmentServer ||
    isLocalPreview ||
    (import.meta.env.PUBLIC_ENABLE_DEV === 'true' && urlParams.has('dev'))
  if (devToolsEnabled) {
    const { initDevTools, handleMapClick } = await import('../map/dev-tools')
    initDevTools({
      getGraph: () => _graph,
      initializeNavigation,
      switchFloor,
      clearRoute,
      redrawRouteForCurrentFloor,
    })
    state.map?.on('click', (e: L.LeafletMouseEvent) => {
      handleMapClick(e.latlng)
    })
  }

  // ========== EVENT LISTENERS ==========

  // Navigation buttons
  const listenerController = new AbortController()
  const listenerSignal = listenerController.signal
  const clearRouteBtn = document.getElementById('clear-route-btn')

  if (clearRouteBtn) clearRouteBtn.addEventListener('click', clearRoute, { signal: listenerSignal })

  const scheduleUi = setupScheduleModal(() => _graph)

  // Floor switcher
  document.querySelectorAll('.floor-btn').forEach((btn) => {
    btn.addEventListener(
      'click',
      () => {
        const floorId = btn.getAttribute('data-floor')
        if (floorId) switchFloor(floorId)
      },
      { signal: listenerSignal }
    )
  })

  const panelBehavior = setupPanelBehavior()
  const { collapseForRoute: collapsePanelForRoute } = panelBehavior
  let requestRoute: () => void = () => undefined
  const routeActions = setupRouteActions({
    getGraph: () => _graph,
    collapsePanel: collapsePanelForRoute,
    refreshRecent: () => refreshRecentSearchesUI(requestRoute),
    showStatus: showStatusMessage,
  })
  requestRoute = routeActions.findRoute

  // Cleanup on page unload
  window.addEventListener('beforeunload', () => {
    for (const m of state.routeMarkers) {
      if ('__isOutline' in m) {
        state.map?.removeLayer(m.layer)
      } else {
        state.map?.removeLayer(m)
      }
    }
    state.routeMarkers = []

    if (state.currentRoute) {
      state.map?.removeLayer(state.currentRoute)
      state.currentRoute = null
    }

    graphController.terminate()
    cancelPendingDataLoad()
    listenerController.abort()
    cleanupSearchUi?.()
    scheduleUi.cleanup()
    routeActions.cleanup()
    panelBehavior.cleanup()

    logger.log('Cleanup completed')
  })
</script>
