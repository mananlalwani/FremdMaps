<div id="map"></div>
<div id="debug-ui">
    <button id="toggle-debug">Enable Debug Mode</button>
    <div
        id="debug-controls"
        style="display: none; flex-direction: column; gap: 5px;"
    >
        <button id="mode-room" class="active-mode">Add Room Node</button>
        <button id="mode-waypoint">Add Waypoint</button>
        <button id="mode-bathroom">Add Bathroom</button>
        <button id="mode-stairway">Add Stairway</button>
        <button id="mode-wall">Add Walls</button>
        <button id="toggle-graph">Show Graph</button>
        <button id="save-data">Save Data</button>
        <div
            id="stats-display"
            style="background: var(--panel-surface); padding: 10px 12px; border-radius: var(--radius-md); font-size: 11px; color: var(--text-secondary); border: 1px solid var(--panel-border); font-family: var(--font-mono);"
        >
            Nodes: <span id="node-count">0</span><br />
            Walls: <span id="wall-count">0</span><br />
            Edges: <span id="edge-count">0</span>
        </div>
    </div>
</div>

<script>
    import L from "leaflet";
    import "leaflet/dist/leaflet.css";
    import { buildVisibilityGraph, getGraphStats } from "../utils/graph";
    import { findPath, findNodeByRoom, findNearestBathroom } from "../utils/pathfinding";
    import { convertWallData, simplifyPath } from "../utils/geometry";
    import type { Graph, Wall, Node, SearchResult, Edge } from "../utils/types";
    import { MAP_CONFIG, API_CONFIG, UI_CONFIG } from "../utils/constants";
    import { logger, graphLogger, searchLogger, routeLogger } from "../utils/logger";
    
    // Search enhancements
    import { 
        searchNodes, 
        findExactMatch, 
        getFeaturedRooms, 
        inferCategory, 
        getCategoryIcon, 
        getCategoryLabel,
        rankWithRecency,
        invalidateSearchCache
    } from "../utils/search";
    import { 
        getRecentSearches, 
        addRecentSearch, 
        clearRecentSearches,
        removeRecentSearch,
        getFavorites, 
        toggleFavorite,
        isFavorite,
        getFrequentRooms,
        trackSearch
    } from "../utils/storage";
    import { FEATURED_ROOMS, SEARCH_CONFIG } from "../config/featured";

    const { IMAGE_WIDTH, IMAGE_HEIGHT, MIN_ZOOM, MAX_ZOOM } = MAP_CONFIG;

    // State
    let isDebugMode = false;
    let currentMode = "room"; // 'room', 'waypoint', 'bathroom', 'stairway', or 'wall'

    // Data
    let collectedNodes = [];
    let collectedWalls = []; // Array of arrays of [lat, lng]

    // Leaflet Objects
    let nodeMarkers = {};
    let wallPolylines = [];
    let currentWallPolyline = null; // The wall currently being drawn
    let map;

    // Navigation State
    let navigationGraph: Graph | null = null;
    let wallObjects: Wall[] = [];
    let currentRoute: L.Polyline | null = null;
    let routeMarkers: L.Marker[] = [];
    let graphEdges: L.Polyline[] = [];
    let showingGraph = false;

    // Search State
    let searchDebounceTimer: number | null = null;
    let activeDropdown: 'start' | 'end' | null = null;
    let currentSearchResults: SearchResult[] = [];
    let selectedStartNode: Node | null = null;
    let selectedEndNode: Node | null = null;

    // UI Elements
    const toggleBtn = document.getElementById("toggle-debug");
    const controlsDiv = document.getElementById("debug-controls");
    const modeRoomBtn = document.getElementById("mode-room");
    const modeWaypointBtn = document.getElementById("mode-waypoint");
    const modeBathroomBtn = document.getElementById("mode-bathroom");
    const modeStairwayBtn = document.getElementById("mode-stairway");
    const modeWallBtn = document.getElementById("mode-wall");
    const toggleGraphBtn = document.getElementById("toggle-graph");
    const saveBtn = document.getElementById("save-data");
    const nodeCountSpan = document.getElementById("node-count");
    const wallCountSpan = document.getElementById("wall-count");
    const edgeCountSpan = document.getElementById("edge-count");

    // ========== SAFE DOM HELPERS (XSS Prevention) ==========
    
    /**
     * Safely set text content (prevents XSS)
     */
    function setText(element: HTMLElement | null, text: string): void {
        if (element) element.textContent = text;
    }
    
    /**
     * Safely create a paragraph element with text
     */
    function createTextParagraph(text: string, style?: string): HTMLParagraphElement {
        const p = document.createElement('p');
        p.textContent = text;
        if (style) p.setAttribute('style', style);
        return p;
    }
    
    /**
     * Safely create a div element with text content
     */
    function createTextDiv(text: string, className?: string): HTMLDivElement {
        const div = document.createElement('div');
        div.textContent = text;
        if (className) div.className = className;
        return div;
    }
    
    /**
     * Safely create a search result item
     */
    function createSearchResultItem(result: SearchResult, onSelect: () => void): HTMLElement {
        const item = document.createElement('div');
        item.className = 'search-result-item';
        
        const icon = document.createElement('span');
        icon.className = 'result-icon';
        icon.textContent = getCategoryIcon(result.node.category || inferCategory(result.node));
        
        const content = document.createElement('div');
        content.className = 'result-content';
        
        const primary = document.createElement('div');
        primary.className = 'result-primary';
        primary.textContent = result.node.rooms[0] || 'Unnamed';
        
        const secondary = document.createElement('div');
        secondary.className = 'result-secondary';
        secondary.textContent = getCategoryLabel(result.node.category || inferCategory(result.node));
        
        content.appendChild(primary);
        content.appendChild(secondary);
        
        item.appendChild(icon);
        item.appendChild(content);
        
        item.addEventListener('click', onSelect);
        
        return item;
    }
    
    /**
     * Safely create a featured room item
     */
    function createFeaturedRoomItem(room: string, onSelect: () => void): HTMLElement {
        const item = document.createElement('div');
        item.className = 'search-result-item featured';
        
        const icon = document.createElement('span');
        icon.className = 'result-icon';
        icon.textContent = '⭐';
        
        const content = document.createElement('div');
        content.className = 'result-content';
        
        const primary = document.createElement('div');
        primary.className = 'result-primary';
        primary.textContent = room;
        
        content.appendChild(primary);
        
        item.appendChild(icon);
        item.appendChild(content);
        
        item.addEventListener('click', onSelect);
        
        return item;
    }
    
    /**
     * Safely create a recent search item
     */
    function createRecentSearchItem(from: string, to: string, onSelect: () => void, onDelete: () => void): HTMLElement {
        const item = document.createElement('div');
        item.className = 'recent-item';
        
        const content = document.createElement('div');
        content.className = 'recent-content';
        
        const fromText = document.createElement('strong');
        fromText.textContent = from;
        
        const separator = document.createElement('span');
        separator.textContent = ' → ';
        separator.className = 'recent-arrow';
        
        const toText = document.createElement('span');
        toText.textContent = to;
        
        content.appendChild(fromText);
        content.appendChild(separator);
        content.appendChild(toText);
        
        const deleteBtn = document.createElement('button');
        deleteBtn.className = 'recent-delete';
        deleteBtn.textContent = '×';
        deleteBtn.setAttribute('aria-label', 'Delete');
        deleteBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            onDelete();
        });
        
        item.appendChild(content);
        item.appendChild(deleteBtn);
        
        item.addEventListener('click', onSelect);
        
        return item;
    }
    
    /**
     * Safely create a favorite item
     */
    function createFavoriteItem(room: string, onSelect: () => void, onToggle: () => void): HTMLElement {
        const item = document.createElement('div');
        item.className = 'favorite-item';
        
        const roomText = document.createElement('span');
        roomText.textContent = room;
        
        const starBtn = document.createElement('button');
        starBtn.className = 'favorite-star active';
        starBtn.textContent = '★';
        starBtn.setAttribute('aria-label', 'Remove from favorites');
        starBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            onToggle();
        });
        
        item.appendChild(roomText);
        item.appendChild(starBtn);
        
        item.addEventListener('click', onSelect);
        
        return item;
    }

    function initMap() {
        const bounds = [
            [-IMAGE_HEIGHT, 0],
            [0, IMAGE_WIDTH],
        ];

        map = L.map("map", {
            crs: L.CRS.Simple,
            minZoom: MIN_ZOOM,
            maxZoom: MAX_ZOOM,
            inertia: false,
            maxBoundsViscosity: 1.0,
            doubleClickZoom: false,
        });

        map.setMaxBounds(bounds);

        // Use imageOverlay for pixel-perfect alignment with wall coordinates
        L.imageOverlay("/aviocl.png", bounds).addTo(map);

        map.fitBounds(bounds);

        map.on("click", onMapClick);
        map.on("dblclick", onMapDoubleClick);

        loadData();
    }

    async function loadData() {
        try {
            const apiUrl = import.meta.env.PUBLIC_API_URL || API_CONFIG.DEFAULT_URL;
            
            // Load Nodes (don't display markers yet - only in debug mode)
            const nodesRes = await fetch(`${apiUrl}${API_CONFIG.ENDPOINTS.NODES}`);
            if (!nodesRes.ok) {
                throw new Error(`Failed to load nodes: ${nodesRes.status} ${nodesRes.statusText}`);
            }
            const nodes = await nodesRes.json();
            collectedNodes = nodes;

            // Load Walls (don't display yet - only in debug mode)
            const wallsRes = await fetch(`${apiUrl}${API_CONFIG.ENDPOINTS.WALLS}`);
            if (!wallsRes.ok) {
                throw new Error(`Failed to load walls: ${wallsRes.status} ${wallsRes.statusText}`);
            }
            const walls = await wallsRes.json();
            collectedWalls = walls;
            
            updateUI();
            
            // Initialize navigation after data loads
            initializeNavigation();
        } catch (err) {
            console.error("Failed to load data:", err);
            const emptyState = document.getElementById('empty-state');
            if (emptyState) {
                emptyState.textContent = '';
                emptyState.appendChild(createTextParagraph('Unable to load navigation data. Please check if the server is running.', 'color: #ff6b6b;'));
            }
        }
    }

    // --- NAVIGATION LOGIC ---
    // Web Worker for graph building (prevents UI freeze)
    let graphWorker: Worker | null = null;
    let isGraphBuilding = false; // Race condition guard
    
    function initializeNavigation() {
        if (collectedNodes.length < 2) {
            console.warn('Not enough nodes for navigation (need at least 2)');
            return;
        }
        
        // Guard against concurrent graph building
        if (isGraphBuilding) {
            console.warn('Graph building already in progress');
            return;
        }
        
        // Convert walls to geometry format
        wallObjects = convertWallData(collectedWalls);
        
        // Build visibility graph using Web Worker (non-blocking)
        console.log('Building navigation graph in background...');
        isGraphBuilding = true;
        
        // Show loading indicator
        const routeStatus = document.getElementById('route-status');
        const emptyState = document.getElementById('empty-state');
        if (emptyState) {
            emptyState.textContent = '';
            emptyState.appendChild(createTextParagraph('Building navigation graph...', 'color: var(--amber-400);'));
        }
        
        // Create worker if not exists
        if (!graphWorker) {
            graphWorker = new Worker('/graph-worker.js');
            
            graphWorker.onmessage = function(e) {
                const graphObj = e.data.graph;
                
                // Convert plain object back to Map
                navigationGraph = new Map();
                for (const [key, value] of Object.entries(graphObj)) {
                    navigationGraph.set(key, value as Edge[]);
                }
                
                // Log statistics
                const stats = getGraphStats(navigationGraph);
                console.log('Graph statistics:', stats);
                
                // Invalidate search cache since nodes may have changed
                invalidateSearchCache();
                
                // Populate room datalist for autocomplete
                initializeSearchEnhancements();
                
                // Restore empty state
                if (emptyState) {
                    emptyState.textContent = '';
                    emptyState.appendChild(createTextParagraph('Enter a starting point and destination to find your route.'));
                }
                
                isGraphBuilding = false; // Clear guard
                console.log('Navigation system ready!');
            };
            
            graphWorker.onerror = function(error) {
                console.error('Graph worker error:', error);
                // Fallback to synchronous building
                console.log('Falling back to synchronous graph building...');
                navigationGraph = buildVisibilityGraph(collectedNodes, wallObjects, MAP_CONFIG.MAX_HALLWAY_DISTANCE);
                
                const stats = getGraphStats(navigationGraph);
                console.log('Graph statistics:', stats);
                
                invalidateSearchCache();
                initializeSearchEnhancements();
                
                if (emptyState) {
                    emptyState.textContent = '';
                    emptyState.appendChild(createTextParagraph('Enter a starting point and destination to find your route.'));
                }
                
                isGraphBuilding = false; // Clear guard
            };
        }
        
        // Send data to worker
        graphWorker.postMessage({
            nodes: collectedNodes,
            walls: wallObjects,
            maxDistance: MAP_CONFIG.MAX_HALLWAY_DISTANCE
        });
    }

    // ========== SEARCH ENHANCEMENTS ==========

    function initializeSearchEnhancements() {
        console.log('Initializing search enhancements...');
        
        // Initialize Recent Searches and Favorites UI
        updateRecentSearchesUI();
        updateFavoritesUI();
        
        // Setup search inputs
        setupSearchInput('start');
        setupSearchInput('end');
        
        console.log('Search enhancements ready!');
    }

    function setupSearchInput(type: 'start' | 'end') {
        const inputId = type === 'start' ? 'start-input' : 'end-input';
        const input = document.getElementById(inputId) as HTMLInputElement;
        const wrapperFor = type === 'start' ? '#start-dropdown-wrapper' : '#end-dropdown-wrapper';
        const dropdownWrapper = document.querySelector(wrapperFor);
        const dropdown = dropdownWrapper?.querySelector('[data-dropdown-container]') as HTMLElement;
        
        if (!input || !dropdown) {
            console.warn(`Search input ${type} not found`);
            return;
        }

        // Input event with debounce
        input.addEventListener('input', (e) => {
            const query = (e.target as HTMLInputElement).value;
            
            // Clear previous timer
            if (searchDebounceTimer) {
                clearTimeout(searchDebounceTimer);
            }
            
            // Debounce search
            searchDebounceTimer = setTimeout(() => {
                handleSearchInput(query, type, dropdown);
            }, SEARCH_CONFIG.DEBOUNCE_MS) as unknown as number;
        });

        // Focus event - show dropdown
        input.addEventListener('focus', () => {
            activeDropdown = type;
            const query = input.value;
            handleSearchInput(query, type, dropdown);
        });

        // Enter key to select first result, Escape to close
        input.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                // Select first result if available
                const resultsList = dropdown.querySelector('[data-results-list]') as HTMLElement;
                const firstItem = resultsList?.querySelector('.search-result-item, .suggestion-item') as HTMLElement;
                if (firstItem) {
                    firstItem.click();
                }
            } else if (e.key === 'Escape') {
                e.preventDefault();
                hideDropdown(dropdown);
                activeDropdown = null;
            }
        });

        // Click outside to close
        document.addEventListener('click', (e) => {
            if (!input.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
                hideDropdown(dropdown);
                activeDropdown = null;
            }
        });
    }

    function handleSearchInput(query: string, type: 'start' | 'end', dropdown: HTMLElement) {
        const trimmedQuery = query.trim();
        
        // Show dropdown
        dropdown.style.display = 'block';
        
        if (trimmedQuery.length === 0) {
            // Show featured/suggestions when empty
            renderFeaturedRooms(dropdown, type);
        } else if (trimmedQuery.length >= SEARCH_CONFIG.MIN_QUERY_LENGTH) {
            // Perform fuzzy search
            let results = searchNodes(trimmedQuery, collectedNodes, {
                limit: SEARCH_CONFIG.MAX_RESULTS
            });
            
            // Rank with recency boost
            const frequentRooms = getFrequentRooms();
            results = rankWithRecency(results, frequentRooms);
            
            // Track search
            trackSearch(trimmedQuery, results.length);
            
            // Render results
            renderSearchResults(results, dropdown, type);
            currentSearchResults = results;
        }
    }

    function renderSearchResults(results: SearchResult[], dropdown: HTMLElement, type: 'start' | 'end') {
        const resultsList = dropdown.querySelector('[data-results-list]') as HTMLElement;
        if (!resultsList) return;
        
        // Clear previous results
        resultsList.textContent = '';
        
        if (results.length === 0) {
            resultsList.appendChild(createTextDiv('No rooms found. Try a different search.', 'search-empty'));
            return;
        }
        
        results.forEach((result) => {
            const item = createSearchResultItem(result, () => {
            });
            resultsList.appendChild(item);
        });
    }

    function renderFeaturedRooms(dropdown: HTMLElement, type: 'start' | 'end') {
        const resultsList = dropdown.querySelector('[data-results-list]') as HTMLElement;
        if (!resultsList) return;
        
        // Clear previous results
        resultsList.textContent = '';
        
        // Add suggestions header
        const header = document.createElement('div');
        header.className = 'suggestions-header';
        header.textContent = 'Popular Destinations';
        resultsList.appendChild(header);
        
        // Show featured rooms
        const featured = getFeaturedRooms();
        featured.forEach(room => {
            const node = findNodeByRoom(room, collectedNodes);
            if (node) {
                const item = createFeaturedRoomItem(room, () => {
                    selectSearchResult(node, type);
                    hideDropdown(dropdown);
                    activeDropdown = null;
                });
                resultsList.appendChild(item);
            }
        });
    }

    function selectSearchResult(node: Node, type: 'start' | 'end') {
        const inputId = type === 'start' ? 'start-input' : 'end-input';
        const input = document.getElementById(inputId) as HTMLInputElement;
        const wrapperSelector = type === 'start' ? '#start-dropdown-wrapper' : '#end-dropdown-wrapper';
        const dropdown = document.querySelector(wrapperSelector + ' [data-dropdown-container]') as HTMLElement;
        
        if (!input) return;
        
        // Set input value
        const roomName = node.rooms.filter(r => r !== 'waypoint')[0] || node.uid;
        input.value = roomName;
        
        // Store selected node
        if (type === 'start') {
            selectedStartNode = node;
        } else {
            selectedEndNode = node;
        }
        
        // Hide dropdown
        hideDropdown(dropdown);
        activeDropdown = null;
        
        console.log(`Selected ${type}: ${roomName}`);
    }

    function hideDropdown(dropdown: HTMLElement) {
        if (dropdown) {
            dropdown.style.display = 'none';
        }
    }

    function handleToggleFavorite(uid: string) {
        const newState = toggleFavorite(uid);
        console.log(`Favorite toggled for ${uid}: ${newState}`);
        
        // Update all favorite stars in dropdowns
        document.querySelectorAll(`[data-uid="${uid}"] .result-favorite`).forEach(star => {
            if (newState) {
                star.classList.add('active');
                star.textContent = '★';
            } else {
                star.classList.remove('active');
                star.textContent = '☆';
            }
        });
        
        // Update favorites UI
        updateFavoritesUI();
    }

    // ========== RECENT SEARCHES UI ==========

    function updateRecentSearchesUI() {
        const container = document.getElementById('recent-searches-container');
        const list = document.getElementById('recent-list');
        const clearBtn = document.getElementById('clear-recent-btn');
        
        if (!container || !list) return;
        
        const recent = getRecentSearches();
        
        if (recent.length === 0) {
            container.style.display = 'none';
            return;
        }
        
        container.style.display = 'block';
        list.textContent = ''; // Clear safely
        
        recent.forEach(entry => {
            const item = createRecentSearchItem(
                entry.from,
                entry.to,
                () => {
                    // Click route to repeat search
                    const startInput = document.getElementById('start-input') as HTMLInputElement;
                    const endInput = document.getElementById('end-input') as HTMLInputElement;
                    if (startInput && endInput) {
                        startInput.value = entry.from;
                        endInput.value = entry.to;
                        handleFindRoute();
                    }
                },
                () => {
                    // Delete this recent search
                    removeRecentSearch(entry.from, entry.to);
                    updateRecentSearchesUI();
                }
            );
            list.appendChild(item);
        });
        
        // Clear all button
        if (clearBtn) {
            clearBtn.onclick = () => {
                clearRecentSearches();
                updateRecentSearchesUI();
            };
        }
    }

    // ========== FAVORITES UI ==========

    function updateFavoritesUI() {
        const container = document.getElementById('favorites-container');
        const list = document.getElementById('favorites-list');
        
        if (!container || !list) return;
        
        const favoriteUIDs = getFavorites();
        const favoriteNodes = collectedNodes.filter((n: Node) => favoriteUIDs.includes(n.uid));
        
        if (favoriteNodes.length === 0) {
            container.style.display = 'none';
            return;
        }
        
        container.style.display = 'block';
        list.textContent = ''; // Clear safely
        
        favoriteNodes.forEach((node: Node) => {
            const roomName = node.rooms.filter(r => r !== 'waypoint').join(', ');
            
            const item = createFavoriteItem(
                roomName,
                () => {
                    // Click to set as destination
                    const endInput = document.getElementById('end-input') as HTMLInputElement;
                    if (endInput) {
                        endInput.value = roomName;
                        selectedEndNode = node;
                    }
                },
                () => {
                    // Click star to unfavorite
                    toggleFavorite(node.uid);
                    updateFavoritesUI();
                }
            );
            
            list.appendChild(item);
        });
    }

    // ========== END SEARCH ENHANCEMENTS ==========

    function populateRoomList() {
        // Deprecated: replaced by search enhancements
        // Keeping for backwards compatibility
        console.log('populateRoomList() called - now handled by search enhancements');
    }

    function handleFindRoute() {
        const startInput = document.getElementById('start-input') as HTMLInputElement;
        const endInput = document.getElementById('end-input') as HTMLInputElement;
        
        if (!startInput || !endInput) return;
        
        const startRoom = startInput.value.trim();
        const endRoom = endInput.value.trim();
        
        if (!startRoom || !endRoom) {
            showStatusMessage('Please enter both start and destination', 'warning');
            return;
        }
        
        if (!navigationGraph) {
            showStatusMessage('Navigation system is still loading. Please wait a moment.', 'warning');
            return;
        }
        
        // Try to use selected nodes from search dropdown first, fallback to text search
        let startNode = selectedStartNode || findNodeByRoom(startRoom, collectedNodes) || findExactMatch(startRoom, collectedNodes);
        let endNode = selectedEndNode || findNodeByRoom(endRoom, collectedNodes) || findExactMatch(endRoom, collectedNodes);
        
        // If still not found, try fuzzy search and use best match
        if (!startNode) {
            const results = searchNodes(startRoom, collectedNodes, { limit: 1 });
            if (results.length > 0 && results[0].score < 0.6) {  // Accept if reasonably close
                startNode = results[0].node;
                console.log(`Using fuzzy match for start: ${startRoom} → ${startNode.rooms[0]}`);
            }
        }
        
        if (!endNode) {
            const results = searchNodes(endRoom, collectedNodes, { limit: 1 });
            if (results.length > 0 && results[0].score < 0.6) {
                endNode = results[0].node;
                console.log(`Using fuzzy match for end: ${endRoom} → ${endNode.rooms[0]}`);
            }
        }
        
        if (!startNode) {
            showStatusMessage(`Starting location "${startRoom}" not found. Try a different search.`, 'error');
            return;
        }
        
        if (!endNode) {
            showStatusMessage(`Destination "${endRoom}" not found. Try a different search.`, 'error');
            return;
        }
        
        // Run A*
        console.log(`Finding path from ${startRoom} to ${endRoom}...`);
        const result = findPath(startNode.uid, endNode.uid, collectedNodes, navigationGraph);
        
        if (!result.found) {
            showStatusMessage('No path found between these locations. They may be on different floors or blocked by walls.', 'error');
            return;
        }
        
        // Save to recent searches
        addRecentSearch(startRoom, endRoom);
        updateRecentSearchesUI();
        
        console.log('Path found:', result);
        
        // Display route
        displayRoute(result.path, result.distance);
    }
    
    // Helper function for user-friendly status messages
    function showStatusMessage(message: string, type: 'info' | 'warning' | 'error' = 'info') {
        const routeStatus = document.getElementById('route-status');
        if (routeStatus) {
            const colors = {
                info: 'var(--amber-400)',
                warning: '#ffca28',
                error: '#ff6b6b'
            };
            routeStatus.style.color = colors[type];
            routeStatus.textContent = message;
            
            // Auto-clear after timeout for non-errors
            if (type !== 'error') {
                setTimeout(() => {
                    if (routeStatus.textContent === message) {
                        routeStatus.textContent = '';
                    }
                }, UI_CONFIG.STATUS_MESSAGE_TIMEOUT_MS);
            }
        } else {
            // Fallback to alert if status element not found
            alert(message);
        }
    }

    function displayRoute(path, totalDistance) {
        // Clear previous route
        clearRoute();
        
        // Simplify path for visualization (removes unnecessary waypoints)
        console.log('Original path length:', path.length)
        const simplifiedPath = simplifyPath(path, MAP_CONFIG.PATH_SIMPLIFICATION_ANGLE);
        console.log('Simplified path length:', simplifiedPath.length)
        
        // Draw path polyline with simplified coordinates
        const coordinates = simplifiedPath.map(n => [n.lat, n.lng]);
        currentRoute = L.polyline(coordinates, {
            color: UI_CONFIG.ROUTE_PATH_COLOR,
            weight: UI_CONFIG.ROUTE_PATH_WEIGHT,
            opacity: 0.9,
            lineCap: 'round',
            lineJoin: 'round',
            className: 'route-path'
        }).addTo(map);
        
        // Add start marker
        const startIcon = L.divIcon({
            className: 'route-marker start',
            html: '<div style="background: #16161e; color: #f0a500; width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; font-family: JetBrains Mono, monospace; border: 2px solid #f0a500; box-shadow: 0 0 16px rgba(240,165,0,0.4)">A</div>',
            iconSize: [30, 30],
            iconAnchor: [15, 15]
        });
        
        const startMarker = L.marker(coordinates[0], { icon: startIcon }).addTo(map);
        routeMarkers.push(startMarker);
        
        // Add end marker
        const endIcon = L.divIcon({
            className: 'route-marker end',
            html: '<div style="background: #f0a500; color: #16161e; width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; font-family: JetBrains Mono, monospace; border: 2px solid #f0a500; box-shadow: 0 0 16px rgba(240,165,0,0.4)">B</div>',
            iconSize: [30, 30],
            iconAnchor: [15, 15]
        });
        
        const endMarker = L.marker(coordinates[coordinates.length - 1], { icon: endIcon }).addTo(map);
        routeMarkers.push(endMarker);
        
        // Fit map to route
        map.fitBounds(currentRoute.getBounds(), { padding: [100, 100] });
        
        // Update UI - show simple route status
        const routeStatus = document.getElementById('route-status');
        const emptyState = document.getElementById('empty-state');
        
        if (routeStatus) routeStatus.style.display = 'block';
        if (emptyState) emptyState.style.display = 'none';
    }

    function clearRoute() {
        // Remove route polyline
        if (currentRoute) {
            map.removeLayer(currentRoute);
            currentRoute = null;
        }
        
        // Remove route markers
        routeMarkers.forEach(m => map.removeLayer(m));
        routeMarkers = [];
        
        // Clear UI
        const routeStatus = document.getElementById('route-status');
        const emptyState = document.getElementById('empty-state');
        const startInput = document.getElementById('start-input') as HTMLInputElement;
        const endInput = document.getElementById('end-input') as HTMLInputElement;
        
        if (routeStatus) routeStatus.style.display = 'none';
        if (emptyState) emptyState.style.display = 'block';
        if (startInput) startInput.value = '';
        if (endInput) endInput.value = '';
        
        // Reset selected nodes
        selectedStartNode = null;
        selectedEndNode = null;
    }

    function handleFindNearestBathroom() {
        const startInput = document.getElementById('start-input') as HTMLInputElement;
        
        if (!startInput) return;
        
        const startRoom = startInput.value.trim();
        
        if (!startRoom) {
            alert('Please enter your starting location first');
            return;
        }
        
        // Find starting node
        const startNode = findNodeByRoom(startRoom, collectedNodes);
        
        if (!startNode) {
            alert(`Room "${startRoom}" not found`);
            return;
        }
        
        // Find nearest bathroom
        const bathroom = findNearestBathroom(startNode, collectedNodes);
        
        if (!bathroom) {
            alert('No bathrooms found on this floor');
            return;
        }
        
        console.log('Nearest bathroom found:', bathroom);
        
        // Check navigation graph is ready
        if (!navigationGraph) {
            alert('Navigation system not ready. Please wait...');
            return;
        }
        
        // Run pathfinding
        console.log(`Finding path from ${startRoom} to ${bathroom.rooms[0]}...`);
        const result = findPath(startNode.uid, bathroom.uid, collectedNodes, navigationGraph);
        
        if (!result.found) {
            alert('Could not find a path to the nearest bathroom. It may be blocked by walls.');
            return;
        }
        
        console.log('Path to bathroom found:', result);
        
        // Display the route
        displayRoute(result.path, result.distance);
    }

    function onMapClick(e) {
        if (!isDebugMode) return;

        if (currentMode === "room") {
            handleRoomNodeClick(e);
        } else if (currentMode === "waypoint") {
            handleWaypointClick(e);
        } else if (currentMode === "bathroom") {
            handleBathroomNodeClick(e);
        } else if (currentMode === "stairway") {
            handleStairwayNodeClick(e);
        } else if (currentMode === "wall") {
            handleWallClick(e);
        }
    }

    function onMapDoubleClick(e) {
        if (!isDebugMode || currentMode !== "wall") return;
        finishCurrentWall();
    }

    // --- NODE LOGIC ---
    function handleRoomNodeClick(e) {
        const input = prompt(
            "Enter Room IDs (comma separated, e.g. '201, 202'):",
        );
        if (!input) return;

        const rooms = input
            .split(",")
            .map((s) => s.trim())
            .filter((s) => s.length > 0);
        if (rooms.length === 0) return;

        const uid = crypto.randomUUID();

        const node = {
            uid: uid,
            rooms: rooms,
            lat: e.latlng.lat,
            lng: e.latlng.lng,
            type: "room"
        };

        collectedNodes.push(node);
        addMarker(node);
        updateUI();
        
        // Rebuild graph if it exists
        if (navigationGraph) {
            initializeNavigation();
        }
    }

    function handleWaypointClick(e) {
        const uid = crypto.randomUUID();

        const node = {
            uid: uid,
            rooms: ["waypoint"],
            lat: e.latlng.lat,
            lng: e.latlng.lng,
            type: "waypoint"
        };

        collectedNodes.push(node);
        addMarker(node);
        updateUI();
        
        // Rebuild graph if it exists
        if (navigationGraph) {
            initializeNavigation();
        }
    }

    function handleBathroomNodeClick(e) {
        const bathroomName = prompt("Enter bathroom name (e.g., 'Bathroom A'):");
        if (!bathroomName) return;
        
        const uid = crypto.randomUUID();
        
        const node = {
            uid: uid,
            rooms: [bathroomName],
            lat: e.latlng.lat,
            lng: e.latlng.lng,
            type: "bathroom",
            floor: "2"  // Current floor
        };
        
        collectedNodes.push(node);
        addMarker(node);
        updateUI();
        
        // Rebuild graph if it exists
        if (navigationGraph) {
            initializeNavigation();
        }
    }

    function handleStairwayNodeClick(e) {
        const stairName = prompt("Enter stairway name (e.g., 'Stairway A'):");
        if (!stairName) return;
        
        const connectsInput = prompt(
            "Enter connected floor node UIDs (comma-separated):\n" +
            "Example: uid-from-floor1, uid-from-floor3\n" +
            "(Leave blank if not yet connected)"
        );
        
        const uid = crypto.randomUUID();
        
        const node = {
            uid: uid,
            rooms: [stairName],
            lat: e.latlng.lat,
            lng: e.latlng.lng,
            type: "stairway",
            floor: "2",  // Current floor
            connectsTo: connectsInput 
                ? connectsInput.split(',').map(s => s.trim()).filter(s => s.length > 0)
                : []
        };
        
        collectedNodes.push(node);
        addMarker(node);
        updateUI();
        
        // Rebuild graph if it exists
        if (navigationGraph) {
            initializeNavigation();
        }
    }

    function addMarker(node) {
        const isBathroom = node.type === "bathroom";
        const isStairway = node.type === "stairway";
        const isWaypoint = node.type === "waypoint" || node.rooms.includes("waypoint");
        
        const container = document.createElement("div");
        
        if (isBathroom) {
            const title = document.createElement("b");
            title.style.color = "#00BCD4";
            title.textContent = `🚻 ${node.rooms.join(", ")}`;
            container.appendChild(title);
            container.appendChild(document.createElement("br"));
            
            if (node.floor) {
                const floor = document.createElement("small");
                floor.textContent = `Floor ${node.floor}`;
                container.appendChild(floor);
                container.appendChild(document.createElement("br"));
            }
        } else if (isStairway) {
            const connections = node.connectsTo?.length || 0;
            const title = document.createElement("b");
            title.style.color = "#9C27B0";
            title.textContent = `🪜 ${node.rooms.join(", ")}`;
            container.appendChild(title);
            container.appendChild(document.createElement("br"));
            
            const info = document.createElement("small");
            info.textContent = `Floor ${node.floor || '?'} • Connects to ${connections} floor(s)`;
            container.appendChild(info);
            container.appendChild(document.createElement("br"));
        } else if (isWaypoint) {
            const title = document.createElement("b");
            title.style.color = "#FF9800";
            title.textContent = "⚡ Waypoint";
            container.appendChild(title);
            container.appendChild(document.createElement("br"));
        } else {
            const title = document.createElement("b");
            title.textContent = node.rooms.join(", ");
            container.appendChild(title);
            container.appendChild(document.createElement("br"));
        }

        const deleteBtn = document.createElement("button");
        deleteBtn.textContent = "Delete";
        deleteBtn.style.cssText =
            "background: #ff4444; color: white; border: none; padding: 5px 10px; cursor: pointer; border-radius: 3px; margin-top: 5px; font-size: 12px;";

        L.DomEvent.on(deleteBtn, "click", (e) => {
            L.DomEvent.stopPropagation(e);
            L.DomEvent.preventDefault(e);
            deleteNode(node.uid);
        });

        container.appendChild(deleteBtn);

        // Different marker icons for each type
        const markerOptions: L.MarkerOptions = {};
        
        // Make markers invisible in user mode
        if (!isDebugMode) {
            markerOptions.opacity = 0;
            markerOptions.icon = L.divIcon({
                className: 'hidden-marker',
                html: '',
                iconSize: [0, 0]
            });
        } else if (isBathroom) {
            markerOptions.icon = L.divIcon({
                className: 'bathroom-marker',
                html: '<div style="background: #00BCD4; color: white; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; border: 2px solid white; box-shadow: 0 0 6px rgba(0,0,0,0.4);">🚻</div>',
                iconSize: [24, 24],
                iconAnchor: [12, 12]
            });
        } else if (isStairway) {
            markerOptions.icon = L.divIcon({
                className: 'stairway-marker',
                html: '<div style="background: #9C27B0; color: white; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; border: 2px solid white; box-shadow: 0 0 6px rgba(0,0,0,0.4);">🪜</div>',
                iconSize: [24, 24],
                iconAnchor: [12, 12]
            });
        } else if (isWaypoint) {
            markerOptions.icon = L.divIcon({
                className: 'waypoint-marker',
                html: '<div style="background: #FF9800; width: 12px; height: 12px; border-radius: 50%; border: 2px solid white; box-shadow: 0 0 4px rgba(0,0,0,0.4);"></div>',
                iconSize: [12, 12],
                iconAnchor: [6, 6]
            });
        }

        const marker = L.marker([node.lat, node.lng], markerOptions)
            .addTo(map)
            .bindPopup(container);

        marker.on("click", () => {
            if (!isDebugMode) marker.closePopup();
        });

        nodeMarkers[node.uid] = marker;
        
        if (isDebugMode) {
            marker.openPopup();
        }
    }

    function deleteNode(uid) {
        if (confirm(`Delete node?`)) {
            if (nodeMarkers[uid]) {
                map.removeLayer(nodeMarkers[uid]);
                delete nodeMarkers[uid];
            }
            collectedNodes = collectedNodes.filter((n) => n.uid !== uid);
            updateUI();
            
            // Rebuild graph
            if (navigationGraph) {
                initializeNavigation();
            }
        }
    }

    // --- WALL LOGIC ---
    function addWallPolyline(wallPts) {
        const polyline = L.polyline(wallPts, {
            color: "red",
            weight: 4,
            opacity: isDebugMode ? 1 : 0  // Invisible in user mode
        }).addTo(map);

        polyline.on("click", (e) => {
            if (!isDebugMode) return;
            L.DomEvent.stopPropagation(e);
            if (confirm("Delete this wall segment?")) {
                deleteWall(polyline);
            }
        });

        wallPolylines.push(polyline);
        return polyline;
    }

    function deleteWall(polyline) {
        const idx = wallPolylines.indexOf(polyline);
        if (idx !== -1) {
            map.removeLayer(polyline);
            wallPolylines.splice(idx, 1);
            collectedWalls.splice(idx, 1);
            updateUI();
        }
    }

    function handleWallClick(e) {
        const point = [e.latlng.lat, e.latlng.lng];

        if (!currentWallPolyline) {
            // Start new wall
            currentWallPolyline = L.polyline([point], {
                color: "red",
                weight: 4,
            }).addTo(map);
        } else {
            // Add point to existing wall
            currentWallPolyline.addLatLng(point);
        }
    }

    function finishCurrentWall() {
        if (!currentWallPolyline) return;

        const latlngs = currentWallPolyline.getLatLngs();
        if (latlngs.length > 1) {
            const wallPoints = latlngs.map((ll) => [ll.lat, ll.lng]);
            collectedWalls.push(wallPoints);
            // Remove the temporary polyline and re-add via helper (adds click listener)
            map.removeLayer(currentWallPolyline);
            addWallPolyline(wallPoints);
        } else {
            map.removeLayer(currentWallPolyline);
        }

        currentWallPolyline = null;
        updateUI();
    }

    // --- UI & UTILS ---
    function updateUI() {
        nodeCountSpan.textContent = collectedNodes.length;
        wallCountSpan.textContent = collectedWalls.length;
        
        // Update edge count if graph exists
        if (navigationGraph && edgeCountSpan) {
            const stats = getGraphStats(navigationGraph);
            edgeCountSpan.textContent = stats.edges.toString();
        }
    }

    function toggleGraphVisualization() {
        if (!navigationGraph) {
            alert('Navigation graph not built yet. Add more nodes first.');
            return;
        }
        
        if (showingGraph) {
            // Hide graph
            graphEdges.forEach(edge => map.removeLayer(edge));
            graphEdges = [];
            showingGraph = false;
            if (toggleGraphBtn) toggleGraphBtn.textContent = 'Show Graph';
        } else {
            // Show graph
            graphEdges = [];
            
            // Draw edges
            navigationGraph.forEach((edges, fromUid) => {
                const fromNode = collectedNodes.find(n => n.uid === fromUid);
                if (!fromNode) return;
                
                edges.forEach(edge => {
                    const toNode = collectedNodes.find(n => n.uid === edge.to);
                    if (!toNode) return;
                    
                    // Only draw each edge once (check if we haven't drawn reverse edge)
                    const alreadyDrawn = graphEdges.some(polyline => {
                        const latlngs = polyline.getLatLngs();
                        return (latlngs[0].lat === toNode.lat && 
                                latlngs[0].lng === toNode.lng &&
                                latlngs[1].lat === fromNode.lat && 
                                latlngs[1].lng === fromNode.lng);
                    });
                    
                    if (alreadyDrawn) return;
                    
                    const polyline = L.polyline([
                        [fromNode.lat, fromNode.lng],
                        [toNode.lat, toNode.lng]
                    ], {
                        color: '#00ff00',
                        weight: 2,
                        opacity: 0.4,
                        dashArray: '5, 5'
                    }).addTo(map);
                    
                    graphEdges.push(polyline);
                });
            });
            
            showingGraph = true;
            if (toggleGraphBtn) toggleGraphBtn.textContent = 'Hide Graph';
            console.log(`Showing ${graphEdges.length} graph edges`);
        }
    }

    function setMode(mode) {
        currentMode = mode;
        // Finish any ongoing wall when switching
        finishCurrentWall();

        // Update Button Styles
        if (modeRoomBtn) modeRoomBtn.style.backgroundColor = mode === "room" ? "#2196F3" : "#ddd";
        if (modeWaypointBtn) modeWaypointBtn.style.backgroundColor = mode === "waypoint" ? "#FF9800" : "#ddd";
        if (modeBathroomBtn) modeBathroomBtn.style.backgroundColor = mode === "bathroom" ? "#00BCD4" : "#ddd";
        if (modeStairwayBtn) modeStairwayBtn.style.backgroundColor = mode === "stairway" ? "#9C27B0" : "#ddd";
        if (modeWallBtn) modeWallBtn.style.backgroundColor = mode === "wall" ? "#f44336" : "#ddd";
    }

    toggleBtn.addEventListener("click", () => {
        isDebugMode = !isDebugMode;
        toggleBtn.textContent = isDebugMode
            ? "Disable Debug Mode"
            : "Enable Debug Mode";
        toggleBtn.style.backgroundColor = isDebugMode ? "#ff4444" : "#4CAF50";
        controlsDiv.style.display = isDebugMode ? "flex" : "none";

        if (isDebugMode) {
            setMode("room"); // Default to room mode
            
            // Show all nodes and walls when entering debug mode
            collectedNodes.forEach((node) => {
                if (!nodeMarkers[node.uid]) {
                    addMarker(node);
                } else {
                    // Update existing marker to be visible
                    const marker = nodeMarkers[node.uid];
                    const isWaypoint = node.type === "waypoint" || node.rooms.includes("waypoint");
                    
                    if (isWaypoint) {
                        marker.setIcon(L.divIcon({
                            className: 'waypoint-marker',
                            html: '<div style="background: #FF9800; width: 12px; height: 12px; border-radius: 50%; border: 2px solid white; box-shadow: 0 0 4px rgba(0,0,0,0.4);"></div>',
                            iconSize: [12, 12],
                            iconAnchor: [6, 6]
                        }));
                    } else {
                        marker.setOpacity(1);
                    }
                }
            });
            
            // Show walls
            wallPolylines.forEach((polyline) => {
                polyline.setStyle({ opacity: 1 });
            });
            
            collectedWalls.forEach((wallPts) => {
                // Check if wall already exists
                const exists = wallPolylines.some(poly => {
                    const latlngs = poly.getLatLngs();
                    return latlngs.length === wallPts.length &&
                           latlngs[0].lat === wallPts[0][0] &&
                           latlngs[0].lng === wallPts[0][1];
                });
                
                if (!exists) {
                    addWallPolyline(wallPts);
                }
            });
        } else {
            finishCurrentWall();
            
            // Hide all nodes when exiting debug mode
            Object.values(nodeMarkers).forEach((marker: L.Marker) => {
                marker.closePopup();
                marker.setIcon(L.divIcon({
                    className: 'hidden-marker',
                    html: '',
                    iconSize: [0, 0]
                }));
            });
            
            // Hide walls (make invisible but still used for pathfinding)
            wallPolylines.forEach((polyline) => {
                polyline.setStyle({ opacity: 0 });
            });
            
            // Also hide graph edges if visible
            if (showingGraph) {
                toggleGraphVisualization();
            }
        }
    });

    if (modeRoomBtn) {
        modeRoomBtn.addEventListener("click", () => setMode("room"));
    }
    
    if (modeWaypointBtn) {
        modeWaypointBtn.addEventListener("click", () => setMode("waypoint"));
    }
    
    if (modeBathroomBtn) {
        modeBathroomBtn.addEventListener("click", () => setMode("bathroom"));
    }
    
    if (modeStairwayBtn) {
        modeStairwayBtn.addEventListener("click", () => setMode("stairway"));
    }
    
    if (modeWallBtn) {
        modeWallBtn.addEventListener("click", () => setMode("wall"));
    }
    
    if (toggleGraphBtn) {
        toggleGraphBtn.addEventListener("click", toggleGraphVisualization);
    }

    saveBtn.addEventListener("click", async () => {
        try {
            const apiUrl = import.meta.env.PUBLIC_API_URL || API_CONFIG.DEFAULT_URL;
            
            if (collectedNodes.length === 0 && collectedWalls.length === 0) {
                alert("No data to save. Add some nodes or walls first.");
                return;
            }
            
            if (collectedNodes.length > 0) {
                const nodesRes = await fetch(`${apiUrl}${API_CONFIG.ENDPOINTS.NODES}`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(collectedNodes),
                });
                
                if (!nodesRes.ok) {
                    const errorData = await nodesRes.json().catch(() => ({ message: 'Unknown error' }));
                    throw new Error(`Failed to save nodes: ${errorData.message || nodesRes.statusText}`);
                }
            }
            
            if (collectedWalls.length > 0) {
                const wallsRes = await fetch(`${apiUrl}${API_CONFIG.ENDPOINTS.WALLS}`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(collectedWalls),
                });
                
                if (!wallsRes.ok) {
                    const errorData = await wallsRes.json().catch(() => ({ message: 'Unknown error' }));
                    throw new Error(`Failed to save walls: ${errorData.message || wallsRes.statusText}`);
                }
            }
            
            alert("Data saved successfully!");
        } catch (err) {
            console.error("Error saving data:", err);
            alert(`Error saving data: ${err instanceof Error ? err.message : 'Unknown error'}`);
        }
    });

    // Navigation event listeners
    const findRouteBtn = document.getElementById('find-route-btn');
    const clearRouteBtn = document.getElementById('clear-route-btn');
    const findBathroomBtn = document.getElementById('find-bathroom-btn');
    
    if (findRouteBtn) {
        findRouteBtn.addEventListener('click', handleFindRoute);
    }
    
    if (clearRouteBtn) {
        clearRouteBtn.addEventListener('click', clearRoute);
    }
    
    if (findBathroomBtn) {
        findBathroomBtn.addEventListener('click', handleFindNearestBathroom);
    }

    // Cleanup function to prevent memory leaks
    function cleanup() {
        // Terminate Web Worker
        if (graphWorker) {
            graphWorker.terminate();
            graphWorker = null;
            console.log('Web Worker terminated');
        }
        
        // Clear graph edges from map
        graphEdges.forEach(edge => map.removeLayer(edge));
        graphEdges = [];
        
        // Clear route markers
        routeMarkers.forEach(marker => map.removeLayer(marker));
        routeMarkers = [];
        
        // Clear current route
        if (currentRoute) {
            map.removeLayer(currentRoute);
            currentRoute = null;
        }
        
        // Note: Event listeners will be automatically cleaned up when the page unloads
        console.log('Cleanup completed');
    }
    
    // Add cleanup on page unload
    window.addEventListener('beforeunload', cleanup);

    initMap();
</script>

<style>
    #map {
        height: 100vh;
        width: 100vw;
        background: #1a1a24;
        position: relative;
    }
    
    /* Custom route path styling */
    :global(.route-path) {
        filter: drop-shadow(0 2px 8px rgba(240, 165, 0, 0.5));
    }
    
    /* Route marker overrides */
    :global(.route-marker) {
        background: transparent !important;
        border: none !important;
    }
    
    #debug-ui {
        position: absolute;
        top: 10px;
        right: 10px;
        z-index: 1000;
        display: flex;
        flex-direction: column;
        gap: 8px;
        align-items: flex-end;
    }
    button {
        padding: 10px 16px;
        border: 1px solid var(--panel-border);
        border-radius: var(--radius-md);
        cursor: pointer;
        background: var(--panel-bg);
        color: var(--text-secondary);
        font-weight: 600;
        font-family: var(--font-mono);
        font-size: 12px;
        transition: all var(--duration-normal) var(--ease-out);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    button:hover {
        border-color: var(--amber-500);
        color: var(--amber-400);
    }
    
    button:active {
        transform: scale(0.97);
    }
    
    .active-mode {
        background: var(--amber-500) !important;
        color: var(--panel-bg) !important;
        border-color: var(--amber-500) !important;
    }
</style>
