---
// SearchDropdown.astro - Custom autocomplete with fuzzy search
---

<div class="search-dropdown" data-dropdown-container style="display: none;">
  <div class="search-results" data-results-list>
    <!-- Populated dynamically -->
  </div>
</div>

<style is:global>
  @keyframes dropdown-reveal {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes result-appear {
    from {
      opacity: 0;
      transform: translateX(-6px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .search-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: var(--panel-surface);
    border: 1px solid var(--amber-500);
    border-radius: var(--radius-lg);
    box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 0 1px var(--amber-glow);
    max-height: 380px;
    overflow: hidden;
    z-index: 1000;
    animation: dropdown-reveal 0.2s var(--ease-out);
    backdrop-filter: blur(12px);
  }

  .search-results {
    padding: var(--space-1);
    overflow-y: auto;
    max-height: 380px;
  }

  .search-result-item {
    padding: 12px 14px;
    cursor: pointer;
    border-radius: var(--radius-md);
    margin: 2px 0;
    transition: all var(--duration-fast) ease;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    border: 1px solid transparent;
    animation: result-appear 0.15s var(--ease-out) backwards;
    -webkit-tap-highlight-color: transparent;
  }
  
  @media (min-width: 768px) {
    .search-result-item {
      padding: 10px 12px;
    }
  }
  
  .search-result-item:nth-child(1) { animation-delay: 0.00s; }
  .search-result-item:nth-child(2) { animation-delay: 0.02s; }
  .search-result-item:nth-child(3) { animation-delay: 0.04s; }
  .search-result-item:nth-child(4) { animation-delay: 0.06s; }
  .search-result-item:nth-child(5) { animation-delay: 0.08s; }
  .search-result-item:nth-child(n+6) { animation-delay: 0.1s; }

  .search-result-item:hover,
  .search-result-item:active {
    background: var(--panel-elevated);
    border-color: var(--amber-500);
    box-shadow: 0 2px 8px rgba(240, 165, 0, 0.1);
    transform: translateX(2px);
  }

  .result-icon {
    font-size: 20px;
    min-width: 24px;
    text-align: center;
    opacity: 0.7;
    color: var(--amber-400);
  }
  
  @media (min-width: 768px) {
    .result-icon {
      font-size: 16px;
      min-width: 20px;
    }
  }

  .result-content {
    flex: 1;
    min-width: 0;
  }

  .result-name {
    font-size: 15px;
    font-weight: 600;
    font-family: var(--font-mono);
    color: var(--text-primary);
    margin-bottom: 1px;
  }
  
  @media (min-width: 768px) {
    .result-name {
      font-size: 14px;
    }
  }

  .result-name .highlight {
    background: var(--amber-glow-strong);
    color: var(--amber-300);
    padding: 0 2px;
    border-radius: 2px;
  }

  .result-category {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
  }

  .result-favorite {
    color: var(--text-muted);
    font-size: 20px;
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out);
    -webkit-tap-highlight-color: transparent;
    padding: 4px;
  }

  .result-favorite:hover,
  .result-favorite:active {
    color: var(--amber-400);
    transform: scale(1.15);
  }

  .result-favorite.active {
    color: var(--amber-500);
  }
  
  @media (min-width: 768px) {
    .result-favorite {
      font-size: 16px;
      padding: 0;
    }
  }
  
  @keyframes star-pop {
    0% { transform: scale(1); }
    50% { transform: scale(1.3) rotate(15deg); }
    100% { transform: scale(1) rotate(0deg); }
  }
  
  .result-favorite.active {
    animation: star-pop 0.3s var(--ease-spring);
  }

  .search-empty {
    padding: var(--space-6);
    text-align: center;
    color: var(--text-muted);
    font-size: 13px;
  }

  .search-suggestions {
    padding: var(--space-2);
  }

  .suggestions-header {
    padding: var(--space-2) var(--space-3);
    font-size: 10px;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-family: var(--font-mono);
  }

  .suggestion-item {
    padding: 8px var(--space-3);
    cursor: pointer;
    border-radius: var(--radius-md);
    transition: background var(--duration-fast);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: 13px;
    color: var(--text-secondary);
  }

  .suggestion-item:hover {
    background: var(--panel-elevated);
  }

  .suggestion-icon {
    font-size: 14px;
    opacity: 0.6;
  }

  /* Category filters */
  .category-filters {
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--panel-border);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .category-chip {
    padding: 4px 10px;
    background: var(--panel-elevated);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-full);
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out);
    display: flex;
    align-items: center;
    gap: 4px;
    color: var(--text-secondary);
    font-family: var(--font-mono);
  }

  .category-chip:hover {
    border-color: var(--amber-500);
    color: var(--amber-400);
  }

  .category-chip.active {
    background: var(--amber-500);
    color: var(--panel-bg);
    border-color: var(--amber-500);
  }

  .category-chip-icon {
    font-size: 12px;
  }

  /* Scrollbar */
  .search-dropdown::-webkit-scrollbar,
  .search-results::-webkit-scrollbar {
    width: 6px;
  }

  .search-dropdown::-webkit-scrollbar-track,
  .search-results::-webkit-scrollbar-track {
    background: transparent;
  }

  .search-dropdown::-webkit-scrollbar-thumb,
  .search-results::-webkit-scrollbar-thumb {
    background: var(--panel-elevated);
    border-radius: var(--radius-full);
  }

  .search-dropdown::-webkit-scrollbar-thumb:hover,
  .search-results::-webkit-scrollbar-thumb:hover {
    background: var(--text-muted);
  }
</style>
