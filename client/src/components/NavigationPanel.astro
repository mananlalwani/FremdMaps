---
import SearchDropdown from './SearchDropdown.astro'
import RecentSearches from './RecentSearches.astro'
import Favorites from './Favorites.astro'
---

<div id="nav-panel">
  <!-- Mobile drag handle -->
  <div id="panel-handle" class="panel-handle">
    <div class="handle-bar"></div>
  </div>
  
  <div class="panel-header">
    <span class="floor-label">Floor 2</span>
    <h2>Wayfinder</h2>
    <p class="panel-subtitle">Indoor Navigation System</p>
    <div class="header-rule"></div>
  </div>
  
  <!-- Favorites Section -->
  <Favorites />
  
  <!-- Recent Searches Section -->
  <RecentSearches />
  
  <!-- Start Location -->
  <div class="input-group" style="position: relative;">
    <label for="start-input">
      <span class="label-icon">📍</span>
      Starting Point
    </label>
    <input 
      type="text" 
      id="start-input" 
      placeholder="e.g., Room 221 or Main Office"
      autocomplete="off"
      data-search-input="start"
    />
    <div id="start-dropdown-wrapper">
      <SearchDropdown />
    </div>
  </div>
  
  <!-- Destination -->
  <div class="input-group" style="position: relative;">
    <label for="end-input">
      <span class="label-icon">🎯</span>
      Destination
    </label>
    <input 
      type="text" 
      id="end-input" 
      placeholder="e.g., Room 129 or Library"
      autocomplete="off"
      data-search-input="end"
    />
    <div id="end-dropdown-wrapper">
      <SearchDropdown />
    </div>
  </div>
  
  <div class="button-group">
    <button id="find-route-btn" class="primary">
      <span class="btn-icon">🧭</span>
      Navigate
    </button>
    <button id="clear-route-btn" class="secondary">
      <span class="btn-icon">✕</span>
      Clear
    </button>
  </div>
  
  <!-- Quick Actions Section -->
  <div class="quick-actions">
    <span class="section-label">Quick Actions</span>
    <button id="find-bathroom-btn" class="quick-action-btn">
      <span class="quick-action-icon">🚻</span>
      <span>Find Nearest Bathroom</span>
    </button>
  </div>
  
  <!-- Route Status -->
  <div id="route-status" style="display: none;">
    <div class="route-info">
      <div class="status-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
      </div>
      <div class="status-text">
        <strong id="route-status-title">Route found!</strong>
        <p id="route-status-details">Follow the path on the map</p>
      </div>
    </div>
  </div>
  
  <!-- Empty State -->
  <div id="empty-state">
    <div class="welcome-header">
      <span class="welcome-icon">👋</span>
      <h3 style="margin: 0; font-size: 18px; font-weight: 600; color: var(--text-primary);">
        Welcome!
      </h3>
    </div>
    <p style="margin: 12px 0 16px; line-height: 1.6; color: var(--text-secondary);">
      Find your way around the building with turn-by-turn directions.
    </p>
    
    <div class="feature-list">
      <div class="feature-item">
        <span class="feature-icon">🔍</span>
        <span>Search rooms by number or name</span>
      </div>
      <div class="feature-item">
        <span class="feature-icon">🗺️</span>
        <span>Automatic multi-floor navigation</span>
      </div>
      <div class="feature-item">
        <span class="feature-icon">🚻</span>
        <span>Locate nearest facilities</span>
      </div>
    </div>
    
    <!-- Quick Demo Examples -->
    <div class="demo-section">
      <p class="demo-header">Try an example:</p>
      <div class="demo-buttons">
        <button class="demo-btn" data-from="253" data-to="129">
          <span>253 → 129</span>
        </button>
        <button class="demo-btn" data-from="221" data-to="124">
          <span>221 → 124</span>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes panel-entrance {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  #nav-panel {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    width: 100%;
    background: var(--panel-bg);
    padding: 0 16px 24px 16px;
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    border: 1px solid var(--panel-border);
    border-bottom: none;
    box-shadow: 0 -8px 32px rgba(0,0,0,0.6);
    z-index: 1000;
    max-height: 45vh;
    overflow-y: auto;
    font-family: var(--font-body);
    transition: max-height var(--duration-slow) var(--ease-out), transform var(--duration-slow) var(--ease-out);
    
    /* Dot grid texture */
    background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.03) 1px, transparent 0);
    background-size: 24px 24px;
    background-color: var(--panel-bg);
  }
  
  #nav-panel.panel-expanded {
    max-height: 85vh;
  }
  
  #nav-panel.panel-minimized {
    max-height: 80px;
    overflow: hidden;
  }
  
  .panel-handle {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 12px 0;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    position: relative;
  }
  
  .panel-handle::after {
    content: 'Tap to expand';
    position: absolute;
    top: 50%;
    right: 16px;
    transform: translateY(-50%);
    font-size: 10px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.6;
    pointer-events: none;
  }
  
  #nav-panel.panel-expanded .panel-handle::after {
    content: 'Tap to collapse';
  }
  
  #nav-panel.panel-minimized .panel-handle::after {
    content: 'Tap to open';
  }
  
  .handle-bar {
    width: 40px;
    height: 4px;
    background: var(--text-muted);
    border-radius: 2px;
    transition: all var(--duration-normal) var(--ease-out);
  }
  
  .panel-handle:active .handle-bar {
    background: var(--amber-500);
    width: 50px;
  }
  
  /* Desktop: left sidebar */
  @media (min-width: 768px) {
    #nav-panel {
      position: absolute;
      top: 16px;
      left: 16px;
      bottom: auto;
      right: auto;
      width: 380px;
      max-width: calc(100vw - 32px);
      border-radius: var(--radius-xl);
      border: 1px solid var(--panel-border);
      max-height: calc(100vh - 32px);
      padding: 24px;
    }
    
    #nav-panel.panel-minimized,
    #nav-panel.panel-expanded {
      max-height: calc(100vh - 32px);
      overflow-y: auto;
    }
    
    .panel-handle {
      display: none;
    }
  }
  
  .panel-header {
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--panel-border);
  }
  
  @media (min-width: 768px) {
    .panel-header {
      margin-bottom: 28px;
      padding-bottom: 20px;
    }
  }
  
  .floor-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--amber-500);
    margin-bottom: 6px;
  }
  
  #nav-panel h2 {
    margin: 0;
    font-size: 28px;
    font-weight: 400;
    font-family: var(--font-display);
    color: var(--text-primary);
    letter-spacing: -0.5px;
    line-height: 1.1;
  }
  
  .panel-subtitle {
    margin: 4px 0 0 0;
    font-size: 11px;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-family: var(--font-mono);
  }
  
  @media (min-width: 768px) {
    #nav-panel h2 {
      font-size: 36px;
    }
  }
  
  .header-rule {
    width: 40px;
    height: 2px;
    background: var(--amber-500);
    margin-top: 16px;
    border-radius: 1px;
  }
  
  .section-label {
    display: block;
    font-size: 10px;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-family: var(--font-mono);
    margin-bottom: var(--space-3);
  }
  
  .input-group {
    margin-bottom: var(--space-3);
    position: relative;
  }
  
  .input-group:first-of-type {
    margin-top: 16px;
  }
  
  @media (min-width: 768px) {
    .input-group {
      margin-bottom: var(--space-4);
    }
    
    .input-group:first-of-type {
      margin-top: 20px;
    }
  }
  
  .input-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: var(--text-secondary);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-family: var(--font-mono);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  
  .label-icon {
    font-size: 14px;
  }
  
  .input-group input {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-md);
    font-size: 16px;
    font-family: var(--font-body);
    transition: all var(--duration-normal) var(--ease-out);
    box-sizing: border-box;
    background: var(--panel-surface);
    color: var(--text-primary);
    box-shadow: var(--shadow-inset);
  }
  
  @media (min-width: 768px) {
    .input-group input {
      padding: 12px 14px;
      font-size: 14px;
    }
  }
  
  .input-group input::placeholder {
    color: var(--text-muted);
    font-weight: 400;
  }
  
  .input-group input:focus {
    outline: none;
    border-color: var(--amber-500);
    box-shadow: 
      var(--shadow-inset),
      0 0 0 3px var(--amber-glow),
      0 2px 8px rgba(0,0,0,0.15);
    background: var(--panel-elevated);
    transform: translateY(-1px);
  }
  
  .button-group {
    display: flex;
    gap: var(--space-2);
    margin-bottom: 20px;
    margin-top: var(--space-2);
  }
  
  button {
    font-size: 15px;
    font-weight: 600;
    font-family: var(--font-body);
    padding: 14px 24px;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  
  .btn-icon {
    font-size: 16px;
    line-height: 1;
  }
  
  @media (min-width: 768px) {
    button {
      font-size: 13px;
      padding: 12px 20px;
    }
  }
  
  button.primary {
    flex: 1;
    background: linear-gradient(135deg, var(--amber-500) 0%, var(--amber-600) 100%);
    color: var(--panel-bg);
    box-shadow: var(--shadow-md), 0 0 20px rgba(240, 165, 0, 0.2);
    position: relative;
    overflow: hidden;
  }
  
  button.primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s;
  }
  
  button.primary:hover::before {
    left: 100%;
  }
  
  button.primary:hover {
    background: linear-gradient(135deg, var(--amber-400) 0%, var(--amber-500) 100%);
    box-shadow: var(--shadow-amber), 0 0 30px rgba(240, 165, 0, 0.3);
    transform: translateY(-2px);
  }
  
  button.primary:active {
    transform: translateY(0);
    box-shadow: var(--shadow-sm);
  }
  
  button.secondary {
    flex: 0 0 auto;
    background: var(--panel-surface);
    color: var(--text-secondary);
    border: 1px solid var(--panel-border);
    position: relative;
  }
  
  button.secondary:hover {
    border-color: var(--panel-border-hover);
    color: var(--text-primary);
    background: var(--panel-elevated);
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }
  
  button.secondary:active {
    transform: scale(0.97);
  }
  
  .quick-actions {
    margin: 20px 0;
    padding: 16px;
    background: var(--panel-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--panel-border);
  }
  
  .quick-actions .section-label {
    margin-bottom: var(--space-3);
  }
  
  .quick-action-btn {
    width: 100%;
    padding: 12px 16px;
    background: transparent;
    border: 1px dashed var(--text-muted) !important;
    color: var(--text-secondary);
    border-radius: var(--radius-md);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out);
    font-family: var(--font-body);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  
  .quick-action-icon {
    font-size: 18px;
  }
  
  .quick-action-btn:hover {
    border-color: var(--amber-500) !important;
    border-style: solid !important;
    color: var(--amber-400);
    background: var(--amber-glow);
  }
  
  .quick-action-btn:active {
    transform: scale(0.98);
  }
  
  .demo-btn {
    padding: 10px 16px !important;
    background: var(--panel-elevated) !important;
    border: 1px solid var(--panel-border) !important;
    color: var(--text-secondary) !important;
    border-radius: var(--radius-md) !important;
    font-size: 13px !important;
    font-weight: 500 !important;
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out);
    font-family: var(--font-mono) !important;
    -webkit-tap-highlight-color: transparent;
    flex: 1;
  }
  
  .demo-btn:hover {
    border-color: var(--amber-500) !important;
    color: var(--amber-400) !important;
    background: var(--amber-glow) !important;
    transform: translateY(-1px);
  }
  
  .demo-btn:active {
    transform: scale(0.97);
  }
  
  @media (min-width: 768px) {
    .demo-btn {
      font-size: 11px !important;
      padding: 8px 12px !important;
    }
  }
  
  /* Empty State Styles */
  #empty-state {
    animation: fadeIn 0.4s var(--ease-out);
  }
  
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .welcome-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }
  
  .welcome-icon {
    font-size: 28px;
    line-height: 1;
  }
  
  .feature-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 16px 0;
  }
  
  .feature-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    background: var(--panel-surface);
    border-radius: var(--radius-md);
    border: 1px solid var(--panel-border);
    font-size: 14px;
    color: var(--text-secondary);
    transition: all var(--duration-normal) var(--ease-out);
  }
  
  .feature-item:hover {
    background: var(--panel-elevated);
    border-color: var(--panel-border-hover);
  }
  
  .feature-icon {
    font-size: 20px;
    min-width: 24px;
    text-align: center;
  }
  
  .demo-section {
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid var(--panel-border);
  }
  
  .demo-header {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .demo-buttons {
    display: flex;
    gap: 8px;
  }
  
  @keyframes status-appear {
    from {
      opacity: 0;
      transform: scale(0.96);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
  
  .route-info {
    margin: 20px 0;
    padding: 16px;
    background: linear-gradient(135deg, var(--success-muted) 0%, rgba(74, 222, 128, 0.08) 100%);
    border: 1px solid rgba(74, 222, 128, 0.3);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    animation: status-appear 0.3s var(--ease-out);
    box-shadow: 0 4px 12px rgba(74, 222, 128, 0.1);
  }

  .status-icon {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, var(--success) 0%, #22c55e 100%);
    color: white;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 2px 8px rgba(74, 222, 128, 0.3);
  }

  .status-text strong {
    display: block;
    color: var(--success);
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 2px;
  }

  .status-text p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 13px;
  }
  
  #empty-state {
    text-align: center;
    padding: var(--space-8) var(--space-4);
    color: var(--text-muted);
  }
  
  #empty-state p {
    margin: 0 0 var(--space-2) 0;
    line-height: 1.5;
    font-size: 13px;
  }
  
  /* Scrollbar styling */
  #nav-panel::-webkit-scrollbar {
    width: 4px;
  }
  
  #nav-panel::-webkit-scrollbar-track {
    background: transparent;
  }
  
  #nav-panel::-webkit-scrollbar-thumb {
    background: var(--panel-elevated);
    border-radius: var(--radius-full);
  }
  
  #nav-panel::-webkit-scrollbar-thumb:hover {
    background: var(--text-muted);
  }
  
  /* Remove excessive responsive rules - now mobile-first */
</style>
