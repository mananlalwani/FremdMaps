<!--
  NavigationPanel.astro — Left sidebar / bottom sheet navigation UI.

  This component is declarative HTML and CSS. Focused modules under src/map/
  own its interactive behavior; the notes below identify their DOM contracts.

  Panel layout (top → bottom):
    1. #panel-handle          — mobile drag handle (tap cycles normal/expanded/minimized)
    2. .panel-header          — title and recent-searches toggle
    3. #recent-dropdown       — slide-down history list (toggled by #recent-toggle-btn)
    4. #favorites-container   — starred rooms; populated by favorites-ui.ts
    5. #start-input / #start-dropdown-wrapper  — "From" search field + autocomplete
    6. #end-input   / #end-dropdown-wrapper    — destination search field + autocomplete
    7. .button-group          — #find-route-btn, #clear-route-btn
    8. .quick-actions         — #find-bathroom-btn, #schedule-btn
    9. #route-status          — status text + #directions-list (turn-by-turn)
   10. #empty-state           — placeholder cleared by initializeNavigation()

  Below the panel, the Schedule Modal (#schedule-modal) is rendered as a fixed
  overlay with two views toggled by schedule-ui.ts:
    - #schedule-view-paths  — read-only route cards; populated by renderPaths()
    - #schedule-view-edit   — period input rows;    populated by renderSchedulePeriods()
-->
<div id="nav-panel" class="dot-grid-bg scrollbar-thin">
  <!-- Mobile drag handle — click toggles expanded and minimized states.
       Handled by panel-behavior.ts.
       Hidden on desktop (≥ 768 px) via CSS. -->
  <button
    id="panel-handle"
    class="panel-handle"
    type="button"
    aria-label="Expand navigation panel"
    aria-controls="nav-panel"
    aria-expanded="false"
  >
    <div class="handle-bar"></div>
  </button>

  <div class="panel-header">
    <div class="header-top">
      <div class="header-title-group">
        <h2>Fremd Maps</h2>
      </div>
      <div class="header-actions">
        <!-- Clock button — toggles #recent-dropdown. search-ui.ts applies
             .has-items for the history badge and .active while open. -->
        <button
          id="recent-toggle-btn"
          class="header-icon-btn"
          aria-label="Recent searches"
          title="Recent searches"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Recent Searches Dropdown — search-ui.ts renders #recent-list, rewires
       #clear-recent-btn, and requests a route when a history item is selected. -->
  <div id="recent-dropdown" class="recent-dropdown" style="display: none;">
    <div class="recent-dropdown-header">
      <span class="recent-dropdown-title">Recent</span>
      <button id="clear-recent-btn" class="clear-button">Clear</button>
    </div>
    <div id="recent-list" class="recent-dropdown-list">
      <!-- Populated by search-ui.ts -->
    </div>
  </div>

  <!-- Favorites are rendered by favorites-ui.ts and hidden when none are saved. -->
  <div class="favorites" id="favorites-container" style="display: none;">
    <div class="favorites-header">
      <span class="section-label">Favorites</span>
    </div>
    <div id="favorites-list" class="favorites-list">
      <!-- Populated by favorites-ui.ts -->
    </div>
  </div>

  <!-- Start Location search field.
       data-search-input="start" identifies this field to setupSearchInput().
       #start-dropdown-wrapper > [data-dropdown-container] is the autocomplete panel.
       [data-results-list] inside the panel is where search results are rendered
       by search-ui.ts. -->
  <div class="input-group">
    <label for="start-input">Start</label>
    <input
      type="text"
      id="start-input"
      placeholder="Room number or name"
      autocomplete="off"
      data-search-input="start"
      role="combobox"
      aria-autocomplete="list"
      aria-controls="start-results-list"
      aria-expanded="false"
    />
    <div id="start-dropdown-wrapper">
      <div
        class="search-dropdown"
        data-dropdown-container
        style="display: none;"
        aria-live="polite"
        aria-atomic="true"
      >
        <div
          id="start-results-list"
          class="search-results scrollbar-thin"
          data-results-list
          role="listbox"
        >
          <!-- Populated by search-ui.ts -->
        </div>
      </div>
    </div>
  </div>

  <!-- Destination search field; search-ui.ts writes the selected node to
       state.selectedEndNode unless the result represents a shared destination. -->
  <div class="input-group">
    <label for="end-input">Destination</label>
    <input
      type="text"
      id="end-input"
      placeholder="Room number or name"
      autocomplete="off"
      data-search-input="end"
      role="combobox"
      aria-autocomplete="list"
      aria-controls="end-results-list"
      aria-expanded="false"
    />
    <div id="end-dropdown-wrapper">
      <div
        class="search-dropdown"
        data-dropdown-container
        style="display: none;"
        aria-live="polite"
        aria-atomic="true"
      >
        <div
          id="end-results-list"
          class="search-results scrollbar-thin"
          data-results-list
          role="listbox"
        >
          <!-- Populated by search-ui.ts -->
        </div>
      </div>
    </div>
  </div>

  <!-- Primary navigation action buttons.
       #find-route-btn  → route-actions.ts (disabled until nodes load)
       #clear-route-btn → clearRoute() from route-display.ts. -->
  <div class="button-group">
    <button id="find-route-btn" class="primary">Go</button>
    <button id="clear-route-btn" class="secondary">Clear</button>
  </div>

  <!-- Quick-action secondary buttons owned by route-actions.ts and schedule-ui.ts. -->
  <div class="quick-actions">
    <button id="find-bathroom-btn" class="quick-action-btn">Find Bathroom</button>
    <button id="schedule-btn" class="quick-action-btn"> My Schedule </button>
  </div>

  <!-- Route status area — hidden until a route is active.
       #route-status-details text is set by showStatusMessage() in Map.astro.
       #directions-list is populated by route-display.ts with
       <li class="direction-step"> elements. -->
  <div id="route-status" style="display: none;" aria-live="polite" aria-atomic="true">
    <p id="route-status-details" class="status-line">Follow the amber path on the map</p>
    <!-- Turn-by-turn directions populated by route-display.ts -->
    <ol id="directions-list" role="list" aria-label="Turn-by-turn directions"></ol>
  </div>

  <!-- Empty state placeholder — cleared (innerHTML = '') by initializeNavigation()
       once nodes have loaded. Can be used for loading spinners or hints. -->
  <div id="empty-state">
    <div class="loading-spinner"></div>
  </div>
</div>

<!-- Schedule Modal — single modal element, two child views toggled by JS.
     z-index: 1100 (above the nav panel at z-index: 1000).
     schedule-ui.ts wires open, close, edit, and save behavior. -->
<div
  id="schedule-modal"
  class="schedule-modal"
  style="display: none;"
  aria-modal="true"
  role="dialog"
  aria-label="My Schedule"
>
  <div class="schedule-modal-inner dot-grid-bg">
    <!-- Paths view (default) — shows consecutive-period route cards.
         #schedule-paths-list populated by renderPaths() in schedule-ui.ts.
         #schedule-edit-btn switches to the edit view.
         #schedule-close-btn closes the modal. -->
    <div id="schedule-view-paths">
      <div class="schedule-modal-header">
        <div class="schedule-modal-title-row">
          <span class="schedule-modal-label">My Schedule</span>
          <div class="schedule-header-btns">
            <button
              id="schedule-edit-btn"
              class="schedule-header-action-btn"
              aria-label="Edit schedule"
            >
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
              </svg>
              Edit
            </button>
            <button id="schedule-close-btn" class="schedule-close-btn" aria-label="Close schedule">
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>
        </div>
        <p class="schedule-modal-subtitle">Tap a route to navigate it.</p>
      </div>
      <div id="schedule-paths-list" class="schedule-paths-list">
        <!-- Populated by renderPaths() in schedule-ui.ts -->
      </div>
    </div>

    <!-- Edit view — shows one text-input row per schedule period.
         #schedule-periods-list populated by schedule-ui.ts.
         Each row gets a body-level autocomplete dropdown (escapes overflow clipping).
         #schedule-back-btn auto-saves and returns to paths view.
         #schedule-save-btn saves and returns to paths view (same as Back).
         #schedule-edit-close-btn closes the modal without explicitly saving
         (the Back/Save buttons must be used to persist edits). -->
    <div id="schedule-view-edit" style="display: none;">
      <div class="schedule-modal-header">
        <div class="schedule-modal-title-row">
          <button
            id="schedule-back-btn"
            class="schedule-header-action-btn"
            aria-label="Back to paths view"
          >
            <svg
              width="13"
              height="13"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back
          </button>
          <button
            id="schedule-edit-close-btn"
            class="schedule-close-btn"
            aria-label="Close schedule"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
        <p class="schedule-modal-subtitle">Set a room for each period.</p>
      </div>
      <div id="schedule-periods-list" class="schedule-periods-list">
        <!-- Populated by renderSchedulePeriods() in Map.astro -->
      </div>
      <div class="schedule-modal-footer">
        <button id="schedule-save-btn" class="primary schedule-save-btn">Save</button>
      </div>
    </div>
  </div>
</div>

<style>
  #nav-panel {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    width: 100%;
    background: var(--panel-bg);
    padding: 0 16px calc(24px + env(safe-area-inset-bottom)) 16px;
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    border-bottom: none;
    box-shadow:
      0 -8px 32px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.08);
    z-index: 1000;
    max-height: 45dvh;
    overflow-y: auto;
    /* Prevent scroll from chaining into the body/map when the panel
       reaches its top or bottom scroll boundary */
    overscroll-behavior: contain;
    /* Suppress 300ms tap delay on the panel's interactive elements */
    touch-action: manipulation;
    font-family: var(--font-body);
    transition:
      max-height var(--duration-slow) var(--ease-out),
      transform var(--duration-slow) var(--ease-out);

    contain: layout paint style;
    will-change: transform;
  }

  #nav-panel.panel-expanded {
    max-height: 85dvh;
  }

  #nav-panel.panel-minimized {
    max-height: 80px;
    overflow: hidden;
  }

  .panel-handle {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 12px 0;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    position: relative;
    min-height: 44px;
    width: 100%;
    border: 0;
    background: transparent;
    color: inherit;
  }

  .panel-handle::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 44px;
    height: 44px;
    pointer-events: none;
  }

  .panel-handle::after {
    content: 'Tap to expand';
    position: absolute;
    top: 50%;
    right: 16px;
    transform: translateY(-50%);
    font-size: 10px;
    color: var(--text-secondary);
    font-family: var(--font-body);
    letter-spacing: 0;
    pointer-events: none;
  }

  #nav-panel.panel-expanded .panel-handle::after {
    content: 'Tap to collapse';
  }

  #nav-panel.panel-minimized .panel-handle::after {
    content: 'Tap to open';
  }

  .handle-bar {
    width: 40px;
    height: 4px;
    background: var(--text-muted);
    border-radius: 2px;
    transition-property: background-color, width;
    transition-duration: var(--duration-normal);
    transition-timing-function: var(--ease-out);
  }

  .panel-handle:active .handle-bar {
    background: var(--amber-500);
    width: 50px;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Desktop: left sidebar */
  @media (min-width: 768px) {
    #nav-panel {
      position: absolute;
      top: 16px;
      left: 16px;
      bottom: auto;
      right: auto;
      width: 380px;
      max-width: calc(100vw - 32px);
      border-radius: var(--radius-xl);
      border: 1px solid var(--panel-border);
      max-height: calc(100dvh - 32px);
      padding: 24px;
    }

    #nav-panel.panel-minimized,
    #nav-panel.panel-expanded {
      max-height: calc(100dvh - 32px);
      overflow-y: auto;
    }

    .panel-handle {
      display: none;
    }
  }

  .panel-header {
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--panel-border);
  }

  .header-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
  }

  .header-title-group {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 6px;
    padding-top: 4px;
    flex-shrink: 0;
  }

  .header-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    background: var(--panel-surface);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-md);
    color: var(--text-muted);
    cursor: pointer;
    flex-shrink: 0;
  }

  .header-icon-btn:hover {
    border-color: var(--amber-500);
    color: var(--amber-500);
    background: var(--panel-elevated);
  }

  .header-icon-btn:active {
    transform: scale(0.96);
  }

  .header-icon-btn.active {
    background: var(--amber-glow);
    border-color: var(--amber-500);
    color: var(--amber-400);
  }

  @media (min-width: 768px) {
    .panel-header {
      margin-bottom: 28px;
      padding-bottom: 20px;
    }
  }

  #nav-panel h2 {
    margin: 0;
    font-size: 23px;
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--amber-400);
    letter-spacing: -0.5px;
    line-height: 1.1;
    text-wrap: balance;
  }

  @media (min-width: 768px) {
    #nav-panel h2 {
      font-size: 26px;
    }
  }

  .input-group {
    margin-bottom: var(--space-3);
    position: relative;
  }

  .input-group:first-of-type {
    margin-top: 16px;
  }

  @media (min-width: 768px) {
    .input-group {
      margin-bottom: var(--space-4);
    }

    .input-group:first-of-type {
      margin-top: 20px;
    }
  }

  .input-group label {
    margin-bottom: 8px;
    font-weight: 600;
    color: var(--text-secondary);
    font-size: 12px;
    letter-spacing: 0;
    font-family: var(--font-body);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .input-group input {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-md);
    font-size: 16px;
    font-family: var(--font-body);
    transition-property: border-color, box-shadow, background-color;
    transition-duration: var(--duration-normal);
    transition-timing-function: var(--ease-out);
    box-sizing: border-box;
    background: var(--panel-surface);
    color: var(--text-primary);
    box-shadow: var(--shadow-inset);
  }

  @media (min-width: 768px) {
    .input-group input {
      padding: 12px 14px;
      font-size: 14px;
    }
  }

  .input-group input::placeholder {
    color: var(--text-muted);
    font-weight: 400;
  }

  .input-group input:focus {
    outline: none;
    border-color: var(--amber-500);
    box-shadow:
      var(--shadow-inset),
      0 0 0 3px var(--amber-glow),
      0 2px 8px rgba(0, 0, 0, 0.15);
    background: var(--panel-elevated);
  }

  @media (max-width: 767px) {
    #nav-panel {
      scroll-padding-bottom: 160px;
    }

    .input-group input {
      font-size: 16px;
    }
  }

  .button-group {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
    margin-top: var(--space-2);
  }

  button {
    font-size: 15px;
    font-weight: 600;
    font-family: var(--font-body);
    padding: 14px 24px;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition-property: background-color, color, border-color, box-shadow, transform;
    transition-duration: var(--duration-normal);
    transition-timing-function: var(--ease-out);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  @media (min-width: 768px) {
    button {
      font-size: 13px;
      padding: 12px 20px;
    }
  }

  button.primary {
    flex: 1;
    background: linear-gradient(135deg, var(--amber-500) 0%, var(--amber-600) 100%);
    color: var(--panel-bg);
    box-shadow:
      var(--shadow-md),
      0 0 20px rgba(240, 165, 0, 0.2);
    position: relative;
    overflow: hidden;
  }

  button.primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transform: translateX(-100%);
    transition-property: transform;
    transition-duration: 500ms;
    transition-timing-function: var(--ease-out);
  }

  button.primary:hover::before {
    transform: translateX(100%);
  }

  button.primary:hover {
    background: linear-gradient(135deg, var(--amber-400) 0%, var(--amber-500) 100%);
    box-shadow:
      var(--shadow-amber),
      0 0 30px rgba(240, 165, 0, 0.3);
    transform: translateY(-2px);
  }

  button.primary:active {
    transform: translateY(0) scale(0.96);
    box-shadow: var(--shadow-sm);
  }

  button.secondary {
    flex: 0 0 auto;
    background: var(--panel-surface);
    color: var(--text-secondary);
    border: 1px solid var(--panel-border);
    position: relative;
  }

  button.secondary:hover {
    border-color: var(--panel-border-hover);
    color: var(--text-primary);
    background: var(--panel-elevated);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  button.secondary:active {
    transform: scale(0.96);
  }

  .quick-actions {
    margin: 12px 0 0 0;
  }

  .quick-action-btn {
    width: 100%;
    padding: 12px 16px;
    background: transparent;
    border: 1px dashed var(--text-muted) !important;
    color: var(--text-secondary);
    border-radius: var(--radius-md);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    font-family: var(--font-body);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    -webkit-tap-highlight-color: transparent;
  }

  .quick-action-btn:hover {
    border-color: var(--amber-500) !important;
    border-style: solid !important;
    color: var(--amber-400);
    background: var(--amber-glow);
  }

  .quick-action-btn:active {
    transform: scale(0.96);
  }

  /* Route status */
  #route-status {
    margin-top: 16px;
  }

  .status-line {
    margin: 0 0 12px 0;
    font-size: 13px;
    color: var(--text-secondary);
    font-family: var(--font-body);
    text-wrap: pretty;
  }

  /* Turn-by-turn directions list */
  #directions-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  #directions-list:empty {
    display: none;
  }

  /* Steps are injected as <li> via innerHTML — use :global so Astro scoped styles apply */

  /* Empty state (JS-injected content) */
  #empty-state {
    color: var(--text-muted);
    font-size: 13px;
    padding: var(--space-4) 0;
  }

  .loading-spinner {
    width: 24px;
    height: 24px;
    border: 2px solid var(--panel-border);
    border-top-color: var(--amber-500);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: var(--space-4) auto;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Scrollbar styling */
  #nav-panel {
    scrollbar-width: thin;
    scrollbar-color: var(--panel-elevated) transparent;
  }
</style>

<!-- Direction step styles, favorites, recent, search, and schedule styles must be global
     because elements are injected via JS/innerHTML and Astro scoped styles don't apply -->
<style is:global>
  .direction-step {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    background: var(--panel-surface);
    border: 1px solid var(--panel-border);
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--text-secondary);
    transition:
      background var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .direction-step.active {
    background: var(--panel-elevated);
    border-color: var(--amber-500);
    color: var(--text-primary);
  }

  .direction-step.completed {
    opacity: 0.45;
  }

  .direction-step-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    font-family: var(--font-body);
  }

  .direction-step-icon.start {
    background: var(--route-start);
    color: white;
  }

  .direction-step-icon.end {
    background: var(--route-end);
    color: white;
  }

  .direction-step-icon.stair {
    background: var(--stair-color);
    color: white;
  }

  .direction-step-icon.walk {
    background: var(--panel-elevated);
    color: var(--text-secondary);
    border: 1px solid var(--panel-border);
  }

  .direction-step-text {
    flex: 1;
    line-height: 1.4;
  }

  .direction-step-text strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .direction-step-floor {
    flex-shrink: 0;
    font-size: 10px;
    font-family: var(--font-body);
    font-weight: 700;
    letter-spacing: 0;
    color: var(--text-muted);
    padding-top: 4px;
    font-variant-numeric: tabular-nums;
  }

  .direction-step.active .direction-step-floor {
    color: var(--amber-500);
  }

  /* ===== Favorites ===== */
  .favorites {
    margin: 0 0 var(--space-4) 0;
    padding: 16px;
    background: var(--panel-surface);
    border: 1px solid var(--amber-glow-strong);
    border-radius: 24px;
    position: relative;
    overflow: hidden;
  }

  .favorites::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--amber-500), transparent);
  }

  .favorites-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }

  .favorites .section-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--text-secondary);
    letter-spacing: 0;
    font-family: var(--font-body);
  }

  .favorites-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .favorite-item {
    min-height: 40px;
    padding: 12px 14px;
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition-property: background-color, border-color;
    transition-duration: var(--duration-fast);
    transition-timing-function: var(--ease-out);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: 15px;
    color: var(--text-primary);
    -webkit-tap-highlight-color: transparent;
    width: 100%;
    text-align: left;
  }

  @media (min-width: 768px) {
    .favorite-item {
      padding: 10px 12px;
      font-size: 13px;
    }
  }

  .favorite-item:hover,
  .favorite-item:active {
    background: var(--amber-glow);
    border-color: rgba(240, 165, 0, 0.15);
  }

  .favorite-select,
  .recent-select {
    flex: 1;
    min-width: 0;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
    font: inherit;
    text-align: left;
  }

  .favorite-icon {
    font-size: 18px;
    opacity: 0.7;
    color: var(--amber-400);
  }

  @media (min-width: 768px) {
    .favorite-icon {
      font-size: 14px;
      opacity: 0.6;
    }
  }

  .favorite-name {
    flex: 1;
    color: var(--text-primary);
    font-weight: 600;
    font-family: var(--font-body);
    font-size: 15px;
  }

  @media (min-width: 768px) {
    .favorite-name {
      font-size: 13px;
    }
  }

  .favorite-category {
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0;
    font-weight: 600;
    font-family: var(--font-body);
  }

  .favorite-star {
    position: relative;
    padding: 4px 8px;
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
    -webkit-tap-highlight-color: transparent;
  }

  .favorite-star::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 44px;
    height: 44px;
  }

  .favorite-star .star-filled {
    color: var(--amber-500);
  }

  .favorite-star .star-empty {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
  }

  .favorite-star:not(.active) .star-filled {
    scale: 0.25;
    opacity: 0;
    filter: blur(4px);
  }

  .favorite-star.active .star-filled {
    scale: 1;
    opacity: 1;
    filter: blur(0);
  }

  .favorite-star:not(.active) .star-empty {
    scale: 1;
    opacity: 1;
    filter: blur(0);
  }

  .favorite-star.active .star-empty {
    scale: 0.25;
    opacity: 0;
    filter: blur(4px);
  }

  .favorite-star:hover .star-filled,
  .favorite-star:hover .star-empty {
    opacity: 1;
  }

  @media (min-width: 768px) {
    .favorite-star {
      padding: 2px 6px;
      font-size: 14px;
    }
  }

  .favorites-empty {
    padding: var(--space-4);
    text-align: center;
    color: var(--text-muted);
    font-size: 12px;
  }

  .favorites-hint {
    font-size: 10px;
    color: var(--text-muted);
    margin-top: var(--space-1);
  }

  /* ===== Recent Searches Dropdown ===== */
  @keyframes recent-reveal {
    from {
      opacity: 0;
      transform: translateY(-4px);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  .recent-dropdown {
    margin: 0 0 var(--space-3) 0;
    background: var(--panel-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08);
    animation: recent-reveal 0.18s var(--ease-out);
    will-change: transform, opacity;
  }

  .recent-dropdown-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    border-bottom: 1px solid var(--panel-border);
  }

  .recent-dropdown-title {
    font-size: 10px;
    font-weight: 700;
    color: var(--text-muted);
    letter-spacing: 0;
    font-family: var(--font-body);
  }

  .clear-button {
    padding: 3px 8px;
    /* Expand tap area to 44px without altering the visual size */
    min-height: 44px;
    background: transparent;
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-sm);
    font-size: 10px;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    transition-property: background-color, color, border-color;
    transition-duration: var(--duration-normal);
    transition-timing-function: var(--ease-out);
    font-family: var(--font-body);
    letter-spacing: 0;
  }

  .clear-button:hover {
    background: var(--error-muted);
    color: var(--error);
    border-color: rgba(248, 113, 113, 0.3);
  }

  .recent-dropdown-list {
    display: flex;
    flex-direction: column;
  }

  .recent-item {
    padding: 10px 14px;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--panel-border);
    cursor: pointer;
    transition-property: background-color;
    transition-duration: var(--duration-fast);
    transition-timing-function: var(--ease-out);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 13px;
    color: var(--text-primary);
    -webkit-tap-highlight-color: transparent;
    width: 100%;
    text-align: left;
  }

  .recent-item:last-child {
    border-bottom: none;
  }

  .recent-item:hover,
  .recent-item:active {
    background: var(--panel-elevated);
  }

  .recent-content {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-body);
    min-width: 0;
    overflow: hidden;
  }

  .recent-content strong {
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 40%;
  }

  .recent-arrow {
    color: var(--text-muted);
    font-size: 10px;
    flex-shrink: 0;
  }

  .recent-content > span:last-of-type {
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 40%;
  }

  .recent-delete {
    min-width: 44px;
    min-height: 44px;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 14px;
    line-height: 1;
    transition: color var(--duration-normal) var(--ease-out);
    opacity: 0.6;
    -webkit-tap-highlight-color: transparent;
    flex-shrink: 0;
  }

  .recent-delete:hover,
  .recent-delete:active {
    color: var(--error);
    opacity: 1;
  }

  /* ===== Search Dropdown ===== */
  @keyframes dropdown-reveal {
    from {
      opacity: 0;
      transform: translateY(-6px);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  @keyframes result-appear {
    from {
      opacity: 0;
      transform: translateX(-6px);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
      filter: blur(0);
    }
  }

  .search-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: var(--panel-surface);
    border: 1px solid var(--amber-500);
    border-radius: 12px;
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.5),
      0 0 0 1px var(--amber-glow);
    max-height: min(380px, 50dvh);
    overflow: hidden;
    z-index: 1000;
    animation: dropdown-reveal 0.2s var(--ease-out);
    backdrop-filter: blur(12px);
    will-change: transform, opacity;
  }

  .search-dropdown.dropdown-hiding,
  .recent-dropdown.dropdown-hiding {
    animation: dropdown-exit 0.12s var(--ease-out) forwards;
  }

  .search-results {
    padding: var(--space-1);
    overflow-y: auto;
    max-height: min(380px, 50dvh);
  }

  .search-result-item {
    min-height: 40px;
    padding: 12px 14px;
    cursor: pointer;
    border-radius: var(--radius-md);
    margin: 2px 0;
    transition-property: background-color, border-color, box-shadow, transform;
    transition-duration: var(--duration-fast);
    transition-timing-function: ease;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    border: 1px solid transparent;
    animation: result-appear 0.15s var(--ease-out) backwards;
    -webkit-tap-highlight-color: transparent;
    width: 100%;
    background: transparent;
    color: inherit;
    font: inherit;
    text-align: left;
  }

  .search-result-row {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .search-result-row .result-favorite {
    flex: 0 0 auto;
  }

  @media (min-width: 768px) {
    .search-result-item {
      padding: 10px 12px;
    }
  }

  .search-result-row:nth-child(1) .search-result-item {
    animation-delay: 0s;
  }
  .search-result-row:nth-child(2) .search-result-item {
    animation-delay: 0.04s;
  }
  .search-result-row:nth-child(3) .search-result-item {
    animation-delay: 0.08s;
  }
  .search-result-row:nth-child(4) .search-result-item {
    animation-delay: 0.12s;
  }
  .search-result-row:nth-child(5) .search-result-item {
    animation-delay: 0.16s;
  }
  .search-result-row:nth-child(n + 6) .search-result-item {
    animation-delay: 0.2s;
  }

  .search-result-item:hover,
  .search-result-item.active,
  .search-result-item:focus-visible {
    background: var(--panel-elevated);
    border-color: var(--amber-500);
    box-shadow: 0 2px 8px rgba(240, 165, 0, 0.1);
    transform: translateX(2px);
  }

  .search-result-item:active {
    transform: scale(0.96);
  }

  .result-icon {
    font-size: 20px;
    min-width: 24px;
    text-align: center;
    opacity: 0.7;
    color: var(--amber-400);
  }

  @media (min-width: 768px) {
    .result-icon {
      font-size: 16px;
      min-width: 20px;
    }
  }

  .result-content {
    flex: 1;
    min-width: 0;
  }

  .result-primary {
    font-size: 15px;
    font-weight: 600;
    font-family: var(--font-body);
    color: var(--text-primary);
    margin-bottom: 1px;
  }

  @media (min-width: 768px) {
    .result-primary {
      font-size: 14px;
    }
  }

  .result-primary .highlight {
    background: var(--amber-glow-strong);
    color: var(--amber-300);
    padding: 0 2px;
    border-radius: 2px;
  }

  .result-secondary {
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0;
    font-weight: 600;
  }

  .result-favorite {
    position: relative;
    color: var(--text-muted);
    font-size: 20px;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .result-favorite .star-filled {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--amber-500);
  }

  .result-favorite .star-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
  }

  .result-favorite:not(.active) .star-filled {
    scale: 0.25;
    opacity: 0;
    filter: blur(4px);
  }

  .result-favorite.active .star-filled {
    scale: 1;
    opacity: 1;
    filter: blur(0);
  }

  .result-favorite:not(.active) .star-empty {
    scale: 1;
    opacity: 1;
    filter: blur(0);
  }

  .result-favorite.active .star-empty {
    scale: 0.25;
    opacity: 0;
    filter: blur(4px);
  }

  .result-favorite:hover,
  .result-favorite:active {
    color: var(--amber-400);
  }

  @media (min-width: 768px) {
    .result-favorite {
      font-size: 16px;
      min-width: 32px;
      min-height: 32px;
    }
  }

  .search-empty {
    padding: var(--space-6);
    text-align: center;
    color: var(--text-muted);
    font-size: 13px;
  }

  .search-suggestions {
    padding: var(--space-2);
  }

  .suggestions-header {
    padding: var(--space-2) var(--space-3);
    font-size: 10px;
    font-weight: 700;
    color: var(--text-muted);
    letter-spacing: 0;
    font-family: var(--font-body);
  }

  .suggestion-item {
    min-height: 40px;
    padding: 8px var(--space-3);
    cursor: pointer;
    border-radius: var(--radius-md);
    transition-property: background-color;
    transition-duration: var(--duration-fast);
    transition-timing-function: var(--ease-out);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: 13px;
    color: var(--text-secondary);
  }

  .suggestion-item:hover {
    background: var(--panel-elevated);
  }

  .suggestion-icon {
    font-size: 14px;
    opacity: 0.6;
  }

  /* ===== Schedule Modal ===== */
  @keyframes dropdown-exit {
    from {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
    to {
      opacity: 0;
      transform: translateY(-6px);
      filter: blur(4px);
    }
  }

  @keyframes schedule-reveal {
    from {
      opacity: 0;
      transform: translateY(16px);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  .schedule-modal {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1100;
    animation: schedule-reveal 0.22s var(--ease-out);
  }

  @media (min-width: 768px) {
    .schedule-modal {
      bottom: auto;
      top: 16px;
      left: 16px;
      right: auto;
      width: 380px;
      max-width: calc(100vw - 32px);
    }
  }

  .schedule-modal-inner {
    background: var(--panel-bg);
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    box-shadow:
      0 -8px 32px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.08);
    max-height: 80dvh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    will-change: transform, opacity;
  }

  @media (min-width: 768px) {
    .schedule-modal-inner {
      border-radius: var(--radius-xl);
      max-height: calc(100dvh - 32px);
    }
  }

  .schedule-modal-header {
    padding: 20px 20px 12px;
    border-bottom: 1px solid var(--panel-border);
    position: sticky;
    top: 0;
    background: var(--panel-bg);
    z-index: 1;
  }

  .schedule-modal-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 6px;
  }

  .schedule-modal-label {
    font-size: 22px;
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--text-primary);
    letter-spacing: -0.6px;
    text-wrap: balance;
  }

  .schedule-close-btn {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 44px !important;
    height: 44px !important;
    padding: 0 !important;
    background: var(--panel-surface) !important;
    border: 1px solid var(--panel-border) !important;
    border-radius: var(--radius-md) !important;
    color: var(--text-secondary) !important;
    cursor: pointer !important;
    transition-property: background-color, color, border-color, transform !important;
    transition-duration: var(--duration-normal) !important;
    transition-timing-function: var(--ease-out) !important;
    -webkit-tap-highlight-color: transparent;
    flex-shrink: 0 !important;
  }

  .schedule-close-btn:hover {
    border-color: var(--amber-500) !important;
    color: var(--amber-400) !important;
    background: var(--panel-elevated) !important;
  }

  .schedule-close-btn:active {
    transform: scale(0.96);
  }

  .schedule-modal-subtitle {
    margin: 0;
    font-size: 12px;
    color: var(--text-muted);
    font-family: var(--font-body);
    text-wrap: pretty;
  }

  /* ===== Period rows ===== */
  .schedule-periods-list {
    flex: 1;
    padding: 8px 0;
  }

  .schedule-period-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 20px;
    border-bottom: 1px solid var(--panel-border);
  }

  .schedule-period-row:last-child {
    border-bottom: none;
  }

  .schedule-period-label {
    font-size: 11px;
    font-weight: 700;
    font-family: var(--font-body);
    color: var(--text-secondary);
    letter-spacing: 0;
    min-width: 52px;
    flex-shrink: 0;
  }

  .schedule-period-input {
    flex: 1;
    min-height: 44px;
    padding: 10px 12px;
    background: var(--panel-surface);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-md);
    /* 16px on mobile prevents iOS Safari from auto-zooming on focus */
    font-size: 16px;
    font-family: var(--font-body);
    color: var(--text-primary);
    transition:
      border-color var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out);
    box-sizing: border-box;
  }

  @media (min-width: 768px) {
    .schedule-period-input {
      font-size: 13px;
    }
  }

  .schedule-period-input::placeholder {
    color: var(--text-muted);
  }

  .schedule-period-input:focus {
    outline: none;
    border-color: var(--amber-500);
    box-shadow: 0 0 0 2px var(--amber-glow);
    background: var(--panel-elevated);
  }

  .schedule-period-nav-btn {
    width: 44px;
    height: 44px;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--panel-surface);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-md);
    color: var(--text-muted);
    cursor: pointer;
    transition-property: background-color, color, border-color, transform;
    transition-duration: var(--duration-fast);
    transition-timing-function: var(--ease-out);
    -webkit-tap-highlight-color: transparent;
    flex-shrink: 0;
  }

  .schedule-period-nav-btn:hover {
    border-color: var(--amber-500);
    color: var(--amber-400);
    background: var(--panel-elevated);
  }

  .schedule-period-nav-btn:active {
    transform: scale(0.96);
  }

  .schedule-period-nav-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* ===== Header action buttons (Edit / Back) ===== */
  .schedule-header-btns {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .schedule-header-action-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 10px 14px 10px 12px;
    background: var(--panel-surface);
    border: 1px solid var(--panel-border);
