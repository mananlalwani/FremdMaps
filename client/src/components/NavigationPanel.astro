---
import SearchDropdown from './SearchDropdown.astro'
import RecentSearches from './RecentSearches.astro'
import Favorites from './Favorites.astro'
---

<div id="nav-panel">
  <!-- Mobile drag handle -->
  <div id="panel-handle" class="panel-handle">
    <div class="handle-bar"></div>
  </div>
  
  <div class="panel-header">
    <span class="floor-label">Floor 2</span>
    <h2>Wayfinder</h2>
    <div class="header-rule"></div>
  </div>
  
  <!-- Favorites Section -->
  <Favorites />
  
  <!-- Recent Searches Section -->
  <RecentSearches />
  
  <!-- Start Location -->
  <div class="input-group" style="position: relative;">
    <label for="start-input">From</label>
    <input 
      type="text" 
      id="start-input" 
      placeholder="Room number or name"
      autocomplete="off"
      data-search-input="start"
    />
    <div id="start-dropdown-wrapper">
      <SearchDropdown />
    </div>
  </div>
  
  <!-- Destination -->
  <div class="input-group" style="position: relative;">
    <label for="end-input">To</label>
    <input 
      type="text" 
      id="end-input" 
      placeholder="Room number or name"
      autocomplete="off"
      data-search-input="end"
    />
    <div id="end-dropdown-wrapper">
      <SearchDropdown />
    </div>
  </div>
  
  <div class="button-group">
    <button id="find-route-btn" class="primary">Navigate</button>
    <button id="clear-route-btn" class="secondary">Clear</button>
  </div>

  <div class="quick-actions">
    <button id="find-bathroom-btn" class="quick-action-btn">
      🚻 Find Nearest Bathroom
    </button>
  </div>

  <!-- Route / empty status text -->
  <div id="route-status" style="display: none;">
    <p id="route-status-details" class="status-line">Follow the amber path on the map</p>
  </div>
  <div id="empty-state"></div>
</div>

<style>
  @keyframes panel-entrance {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  #nav-panel {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    width: 100%;
    background: var(--panel-bg);
    padding: 0 16px 24px 16px;
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    border: 1px solid var(--panel-border);
    border-bottom: none;
    box-shadow: 0 -8px 32px rgba(0,0,0,0.6);
    z-index: 1000;
    max-height: 45vh;
    overflow-y: auto;
    font-family: var(--font-body);
    transition: max-height var(--duration-slow) var(--ease-out), transform var(--duration-slow) var(--ease-out);
    
    /* Dot grid texture */
    background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.03) 1px, transparent 0);
    background-size: 24px 24px;
    background-color: var(--panel-bg);
  }
  
  #nav-panel.panel-expanded {
    max-height: 85vh;
  }
  
  #nav-panel.panel-minimized {
    max-height: 80px;
    overflow: hidden;
  }
  
  .panel-handle {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 12px 0;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    position: relative;
  }
  
  .panel-handle::after {
    content: 'Tap to expand';
    position: absolute;
    top: 50%;
    right: 16px;
    transform: translateY(-50%);
    font-size: 10px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.6;
    pointer-events: none;
  }
  
  #nav-panel.panel-expanded .panel-handle::after {
    content: 'Tap to collapse';
  }
  
  #nav-panel.panel-minimized .panel-handle::after {
    content: 'Tap to open';
  }
  
  .handle-bar {
    width: 40px;
    height: 4px;
    background: var(--text-muted);
    border-radius: 2px;
    transition: all var(--duration-normal) var(--ease-out);
  }
  
  .panel-handle:active .handle-bar {
    background: var(--amber-500);
    width: 50px;
  }
  
  /* Desktop: left sidebar */
  @media (min-width: 768px) {
    #nav-panel {
      position: absolute;
      top: 16px;
      left: 16px;
      bottom: auto;
      right: auto;
      width: 380px;
      max-width: calc(100vw - 32px);
      border-radius: var(--radius-xl);
      border: 1px solid var(--panel-border);
      max-height: calc(100vh - 32px);
      padding: 24px;
    }
    
    #nav-panel.panel-minimized,
    #nav-panel.panel-expanded {
      max-height: calc(100vh - 32px);
      overflow-y: auto;
    }
    
    .panel-handle {
      display: none;
    }
  }
  
  .panel-header {
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--panel-border);
  }
  
  @media (min-width: 768px) {
    .panel-header {
      margin-bottom: 28px;
      padding-bottom: 20px;
    }
  }
  
  .floor-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--amber-500);
    margin-bottom: 6px;
  }
  
  #nav-panel h2 {
    margin: 0;
    font-size: 28px;
    font-weight: 400;
    font-family: var(--font-display);
    color: var(--text-primary);
    letter-spacing: -0.5px;
    line-height: 1.1;
  }
  
  @media (min-width: 768px) {
    #nav-panel h2 {
      font-size: 36px;
    }
  }
  
  .header-rule {
    width: 40px;
    height: 2px;
    background: var(--amber-500);
    margin-top: 16px;
    border-radius: 1px;
  }
  
  .input-group {
    margin-bottom: var(--space-3);
    position: relative;
  }
  
  .input-group:first-of-type {
    margin-top: 16px;
  }
  
  @media (min-width: 768px) {
    .input-group {
      margin-bottom: var(--space-4);
    }
    
    .input-group:first-of-type {
      margin-top: 20px;
    }
  }
  
  .input-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: var(--text-secondary);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-family: var(--font-mono);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  
  .input-group input {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-md);
    font-size: 16px;
    font-family: var(--font-body);
    transition: all var(--duration-normal) var(--ease-out);
    box-sizing: border-box;
    background: var(--panel-surface);
    color: var(--text-primary);
    box-shadow: var(--shadow-inset);
  }
  
  @media (min-width: 768px) {
    .input-group input {
      padding: 12px 14px;
      font-size: 14px;
    }
  }
  
  .input-group input::placeholder {
    color: var(--text-muted);
    font-weight: 400;
  }
  
  .input-group input:focus {
    outline: none;
    border-color: var(--amber-500);
    box-shadow: 
      var(--shadow-inset),
      0 0 0 3px var(--amber-glow),
      0 2px 8px rgba(0,0,0,0.15);
    background: var(--panel-elevated);
    transform: translateY(-1px);
  }
  
  .button-group {
    display: flex;
    gap: var(--space-2);
    margin-bottom: 20px;
    margin-top: var(--space-2);
  }
  
  button {
    font-size: 15px;
    font-weight: 600;
    font-family: var(--font-body);
    padding: 14px 24px;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  
  @media (min-width: 768px) {
    button {
      font-size: 13px;
      padding: 12px 20px;
    }
  }
  
  button.primary {
    flex: 1;
    background: linear-gradient(135deg, var(--amber-500) 0%, var(--amber-600) 100%);
    color: var(--panel-bg);
    box-shadow: var(--shadow-md), 0 0 20px rgba(240, 165, 0, 0.2);
    position: relative;
    overflow: hidden;
  }
  
  button.primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s;
  }
  
  button.primary:hover::before {
    left: 100%;
  }
  
  button.primary:hover {
    background: linear-gradient(135deg, var(--amber-400) 0%, var(--amber-500) 100%);
    box-shadow: var(--shadow-amber), 0 0 30px rgba(240, 165, 0, 0.3);
    transform: translateY(-2px);
  }
  
  button.primary:active {
    transform: translateY(0);
    box-shadow: var(--shadow-sm);
  }
  
  button.secondary {
    flex: 0 0 auto;
    background: var(--panel-surface);
    color: var(--text-secondary);
    border: 1px solid var(--panel-border);
    position: relative;
  }
  
  button.secondary:hover {
    border-color: var(--panel-border-hover);
    color: var(--text-primary);
    background: var(--panel-elevated);
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }
  
  button.secondary:active {
    transform: scale(0.97);
  }
  
  .quick-actions {
    margin: 12px 0 0 0;
  }
  
  .quick-action-btn {
    width: 100%;
    padding: 12px 16px;
    background: transparent;
    border: 1px dashed var(--text-muted) !important;
    color: var(--text-secondary);
    border-radius: var(--radius-md);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out);
    font-family: var(--font-body);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    -webkit-tap-highlight-color: transparent;
  }
  
  .quick-action-btn:hover {
    border-color: var(--amber-500) !important;
    border-style: solid !important;
    color: var(--amber-400);
    background: var(--amber-glow);
  }
  
  .quick-action-btn:active {
    transform: scale(0.98);
  }

  /* Route status */
  #route-status {
    margin-top: 16px;
  }

  .status-line {
    margin: 0;
    font-size: 13px;
    color: var(--text-secondary);
    font-family: var(--font-body);
  }
  
  /* Empty state (JS-injected content) */
  #empty-state {
    color: var(--text-muted);
    font-size: 13px;
    padding: var(--space-4) 0;
  }
  
  /* Scrollbar styling */
  #nav-panel::-webkit-scrollbar {
    width: 4px;
  }
  
  #nav-panel::-webkit-scrollbar-track {
    background: transparent;
  }
  
  #nav-panel::-webkit-scrollbar-thumb {
    background: var(--panel-elevated);
    border-radius: var(--radius-full);
  }
  
  #nav-panel::-webkit-scrollbar-thumb:hover {
    background: var(--text-muted);
  }
  
  /* Remove excessive responsive rules - now mobile-first */
</style>
