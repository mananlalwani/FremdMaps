<!--
  NavigationPanel.astro — Left sidebar / bottom sheet navigation UI.

  This component is purely declarative HTML+CSS; all interactive behaviour is
  driven by the <script> block in Map.astro.  The sections below document which
  element IDs are referenced by Map.astro JS and what each section is used for.

  Panel layout (top → bottom):
    1. #panel-handle          — mobile drag handle (tap cycles normal/expanded/minimized)
    2. .panel-header          — title ("Wayfinder"), floor label, recent-searches toggle
    3. #recent-dropdown       — slide-down history list (toggled by #recent-toggle-btn)
    4. #favorites-container   — starred rooms; populated by updateFavoritesUI()
    5. #start-input / #start-dropdown-wrapper  — "From" search field + autocomplete
    6. #end-input   / #end-dropdown-wrapper    — "To"   search field + autocomplete
    7. .button-group          — #find-route-btn, #clear-route-btn
    8. .quick-actions         — #find-bathroom-btn, #schedule-btn
    9. #route-status          — status text + #directions-list (turn-by-turn)
   10. #empty-state           — placeholder cleared by initializeNavigation()

  Below the panel, the Schedule Modal (#schedule-modal) is rendered as a fixed
  overlay with two views toggled by setupScheduleModal() in Map.astro:
    - #schedule-view-paths  — read-only route cards; populated by renderAllPaths()
    - #schedule-view-edit   — period input rows;    populated by renderSchedulePeriods()
-->

<div id="nav-panel">
  <!-- Mobile drag handle — click cycles: normal → expanded → minimized.
       Handled by panelHandle click listener in Map.astro.
       Hidden on desktop (≥ 768 px) via CSS. -->
  <div id="panel-handle" class="panel-handle">
    <div class="handle-bar"></div>
  </div>
  
  <div class="panel-header">
    <div class="header-top">
      <div class="header-title-group">
        <!-- .floor-label text is updated by switchFloor() in map-init.ts -->
        <span class="floor-label">Floor 2</span>
        <h2>Wayfinder</h2>
      </div>
      <div class="header-actions">
        <!-- Clock button — toggles #recent-dropdown visibility.
             Gets .has-items class when recent history is non-empty (adds badge dot).
             Gets .active class when dropdown is open.
             Wired by setupRecentToggle() in Map.astro. -->
        <button id="recent-toggle-btn" class="header-icon-btn" aria-label="Recent searches" title="Recent searches">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </button>
      </div>
    </div>
    <div class="header-rule"></div>
  </div>

  <!-- Recent Searches Dropdown — toggled by #recent-toggle-btn.
       #recent-list populated by updateRecentSearchesUI() in Map.astro.
       #clear-recent-btn wired by updateRecentSearchesUI() each time it renders.
       Clicking a recent item populates both inputs and calls handleFindRoute(). -->
  <div id="recent-dropdown" class="recent-dropdown" style="display: none;">
    <div class="recent-dropdown-header">
      <span class="recent-dropdown-title">Recent</span>
      <button id="clear-recent-btn" class="clear-button">Clear</button>
    </div>
    <div id="recent-list" class="recent-dropdown-list">
      <!-- Populated by updateRecentSearchesUI() in Map.astro -->
    </div>
  </div>
  
  <!-- Favourites Section — hidden when no favourites are saved.
       Shown/hidden and populated by updateFavoritesUI() in Map.astro.
       Clicking an item sets #end-input + state.selectedEndNode.
       Star buttons call toggleFavorite() and re-render this section. -->
  <div class="favorites" id="favorites-container" style="display: none;">
    <div class="favorites-header">
      <span class="section-label">Favorites</span>
    </div>
    <div id="favorites-list" class="favorites-list">
      <!-- Populated by updateFavoritesUI() in Map.astro -->
    </div>
  </div>
  
  <!-- Start Location search field.
       data-search-input="start" identifies this field to setupSearchInput().
       #start-dropdown-wrapper > [data-dropdown-container] is the autocomplete panel.
       [data-results-list] inside the panel is where search results are rendered
       by renderSearchResults() / renderFeaturedRooms() in Map.astro. -->
  <div class="input-group" style="position: relative;">
    <label for="start-input">From</label>
    <input 
      type="text" 
      id="start-input" 
      placeholder="Room number or name"
      autocomplete="off"
      data-search-input="start"
    />
    <div id="start-dropdown-wrapper">
      <div class="search-dropdown" data-dropdown-container style="display: none;">
        <div class="search-results" data-results-list>
          <!-- Populated by renderSearchResults() / renderFeaturedRooms() in Map.astro -->
        </div>
      </div>
    </div>
  </div>
  
  <!-- Destination search field.
       Mirrors #start-input setup; results written to state.selectedEndNode. -->
  <div class="input-group" style="position: relative;">
    <label for="end-input">To</label>
    <input 
      type="text" 
      id="end-input" 
      placeholder="Room number or name"
      autocomplete="off"
      data-search-input="end"
    />
    <div id="end-dropdown-wrapper">
      <div class="search-dropdown" data-dropdown-container style="display: none;">
        <div class="search-results" data-results-list>
          <!-- Populated by renderSearchResults() / renderFeaturedRooms() in Map.astro -->
        </div>
      </div>
    </div>
  </div>
  
  <!-- Primary navigation action buttons.
       #find-route-btn  → handleFindRoute()   (disabled until nodes load)
       #clear-route-btn → clearRoute()        (from route-display.ts)
       Both wired in the event-listeners section of Map.astro. -->
  <div class="button-group">
    <button id="find-route-btn" class="primary">Navigate</button>
    <button id="clear-route-btn" class="secondary">Clear</button>
  </div>

  <!-- Quick-action secondary buttons.
       #find-bathroom-btn → handleFindNearestBathroom() in Map.astro
       #schedule-btn      → openScheduleModal()         in Map.astro -->
  <div class="quick-actions">
    <button id="find-bathroom-btn" class="quick-action-btn">
      Find Nearest Bathroom
    </button>
    <button id="schedule-btn" class="quick-action-btn schedule-quick-btn">
      My Schedule
    </button>
  </div>

  <!-- Route status area — hidden until a route is active.
       #route-status-details text is set by showStatusMessage() in Map.astro.
       #directions-list is populated by generateDirections() in route-display.ts;
       items are <li class="direction-step"> elements injected via innerHTML
       (see <style is:global> below for why global styles are required). -->
  <div id="route-status" style="display: none;">
    <p id="route-status-details" class="status-line">Follow the amber path on the map</p>
    <!-- Turn-by-turn directions populated by route-display.ts -->
    <ol id="directions-list" role="list" aria-label="Turn-by-turn directions"></ol>
  </div>

  <!-- Empty state placeholder — cleared (innerHTML = '') by initializeNavigation()
       once nodes have loaded. Can be used for loading spinners or hints. -->
  <div id="empty-state"></div>
</div>

<!-- Schedule Modal — single modal element, two child views toggled by JS.
     z-index: 1100 (above the nav panel at z-index: 1000).
     setupScheduleModal() in Map.astro wires all open/close/edit/save logic. -->
<div id="schedule-modal" class="schedule-modal" style="display: none;" aria-modal="true" role="dialog" aria-label="My Schedule">
  <div class="schedule-modal-inner">

    <!-- Paths view (default) — shows consecutive-period route cards.
         #schedule-paths-list populated by renderAllPaths() in Map.astro.
         #schedule-edit-btn switches to the edit view.
         #schedule-close-btn closes the modal. -->
    <div id="schedule-view-paths">
      <div class="schedule-modal-header">
        <div class="schedule-modal-title-row">
          <span class="schedule-modal-label">My Schedule</span>
          <div class="schedule-header-btns">
            <button id="schedule-edit-btn" class="schedule-header-action-btn" aria-label="Edit schedule">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
              </svg>
              Edit
            </button>
            <button id="schedule-close-btn" class="schedule-close-btn" aria-label="Close schedule">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>
        </div>
        <p class="schedule-modal-subtitle">Tap a route to navigate it.</p>
      </div>
      <div id="schedule-paths-list" class="schedule-paths-list">
        <!-- Populated by renderAllPaths() in Map.astro -->
      </div>
    </div>

    <!-- Edit view — shows one text-input row per schedule period.
         #schedule-periods-list populated by renderSchedulePeriods() in Map.astro.
         Each row gets a body-level autocomplete dropdown (escapes overflow clipping).
         #schedule-back-btn auto-saves and returns to paths view.
         #schedule-save-btn saves and returns to paths view (same as Back).
         #schedule-edit-close-btn closes the modal without explicitly saving
         (the Back/Save buttons must be used to persist edits). -->
    <div id="schedule-view-edit" style="display: none;">
      <div class="schedule-modal-header">
        <div class="schedule-modal-title-row">
          <button id="schedule-back-btn" class="schedule-header-action-btn" aria-label="Back to paths view">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back
          </button>
          <button id="schedule-edit-close-btn" class="schedule-close-btn" aria-label="Close schedule">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
        <p class="schedule-modal-subtitle">Set a room for each period.</p>
      </div>
      <div id="schedule-periods-list" class="schedule-periods-list">
        <!-- Populated by renderSchedulePeriods() in Map.astro -->
      </div>
      <div class="schedule-modal-footer">
        <button id="schedule-save-btn" class="primary schedule-save-btn">Save</button>
      </div>
    </div>

  </div>
</div>

<style>
  @keyframes panel-entrance {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  #nav-panel {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    width: 100%;
    background: var(--panel-bg);
    padding: 0 16px 24px 16px;
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    border: 1px solid var(--panel-border);
    border-bottom: none;
    box-shadow: 0 -8px 32px rgba(0,0,0,0.6);
    z-index: 1000;
    max-height: 45vh;
    overflow-y: auto;
    font-family: var(--font-body);
    transition: max-height var(--duration-slow) var(--ease-out), transform var(--duration-slow) var(--ease-out);
    
    /* Dot grid texture */
    background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.03) 1px, transparent 0);
    background-size: 24px 24px;
    background-color: var(--panel-bg);
  }
  
  #nav-panel.panel-expanded {
    max-height: 85vh;
  }
  
  #nav-panel.panel-minimized {
    max-height: 80px;
    overflow: hidden;
  }
  
  .panel-handle {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 12px 0;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    position: relative;
  }
  
  .panel-handle::after {
    content: 'Tap to expand';
    position: absolute;
    top: 50%;
    right: 16px;
    transform: translateY(-50%);
    font-size: 10px;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 1px;
    pointer-events: none;
  }
  
  #nav-panel.panel-expanded .panel-handle::after {
    content: 'Tap to collapse';
  }
  
  #nav-panel.panel-minimized .panel-handle::after {
    content: 'Tap to open';
  }
  
  .handle-bar {
    width: 40px;
    height: 4px;
    background: var(--text-muted);
    border-radius: 2px;
    transition: all var(--duration-normal) var(--ease-out);
  }
  
  .panel-handle:active .handle-bar {
    background: var(--amber-500);
    width: 50px;
  }
  
  /* Desktop: left sidebar */
  @media (min-width: 768px) {
    #nav-panel {
      position: absolute;
      top: 16px;
      left: 16px;
      bottom: auto;
      right: auto;
      width: 380px;
      max-width: calc(100vw - 32px);
      border-radius: var(--radius-xl);
      border: 1px solid var(--panel-border);
      max-height: calc(100vh - 32px);
      padding: 24px;
    }
    
    #nav-panel.panel-minimized,
    #nav-panel.panel-expanded {
      max-height: calc(100vh - 32px);
      overflow-y: auto;
    }
    
    .panel-handle {
      display: none;
    }
  }
  
  .panel-header {
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--panel-border);
  }

  .header-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
  }

  .header-title-group {
    flex: 1;
    min-width: 0;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 6px;
    padding-top: 4px;
    flex-shrink: 0;
  }

  .header-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    background: var(--panel-surface);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-md);
    color: var(--text-muted);
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out);
    -webkit-tap-highlight-color: transparent;
    flex-shrink: 0;
  }

  .header-icon-btn:hover {
    border-color: var(--amber-500);
    color: var(--amber-400);
    background: var(--panel-elevated);
  }

  .header-icon-btn:active {
    transform: scale(0.93);
  }

  .header-icon-btn.active {
    background: var(--amber-glow);
    border-color: var(--amber-500);
    color: var(--amber-400);
  }
  
  @media (min-width: 768px) {
    .panel-header {
      margin-bottom: 28px;
      padding-bottom: 20px;
    }
  }
  
  .floor-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--amber-500);
    margin-bottom: 6px;
  }
  
  #nav-panel h2 {
    margin: 0;
    font-size: 28px;
    font-weight: 400;
    font-family: var(--font-display);
    color: var(--text-primary);
    letter-spacing: -0.5px;
    line-height: 1.1;
  }
  
  @media (min-width: 768px) {
    #nav-panel h2 {
      font-size: 36px;
    }
  }
  
  .header-rule {
    width: 40px;
    height: 2px;
    background: var(--amber-500);
    margin-top: 16px;
    border-radius: 1px;
  }
  
  .input-group {
    margin-bottom: var(--space-3);
    position: relative;
  }
  
  .input-group:first-of-type {
    margin-top: 16px;
  }
  
  @media (min-width: 768px) {
    .input-group {
      margin-bottom: var(--space-4);
    }
    
    .input-group:first-of-type {
      margin-top: 20px;
    }
  }
  
  .input-group label {
    margin-bottom: 8px;
    font-weight: 600;
    color: var(--text-secondary);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-family: var(--font-mono);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  
  .input-group input {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-md);
    font-size: 16px;
    font-family: var(--font-body);
    transition: all var(--duration-normal) var(--ease-out);
    box-sizing: border-box;
    background: var(--panel-surface);
    color: var(--text-primary);
    box-shadow: var(--shadow-inset);
  }
  
  @media (min-width: 768px) {
    .input-group input {
      padding: 12px 14px;
      font-size: 14px;
    }
  }
  
  .input-group input::placeholder {
    color: var(--text-muted);
    font-weight: 400;
  }
  
  .input-group input:focus {
    outline: none;
    border-color: var(--amber-500);
    box-shadow: 
      var(--shadow-inset),
      0 0 0 3px var(--amber-glow),
      0 2px 8px rgba(0,0,0,0.15);
    background: var(--panel-elevated);
  }
  
  .button-group {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
    margin-top: var(--space-2);
  }
  
  button {
    font-size: 15px;
    font-weight: 600;
    font-family: var(--font-body);
    padding: 14px 24px;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  
  @media (min-width: 768px) {
    button {
      font-size: 13px;
      padding: 12px 20px;
    }
  }
  
  button.primary {
    flex: 1;
    background: linear-gradient(135deg, var(--amber-500) 0%, var(--amber-600) 100%);
    color: var(--panel-bg);
    box-shadow: var(--shadow-md), 0 0 20px rgba(240, 165, 0, 0.2);
    position: relative;
    overflow: hidden;
  }
  
  button.primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s;
  }
  
  button.primary:hover::before {
    left: 100%;
  }
  
  button.primary:hover {
    background: linear-gradient(135deg, var(--amber-400) 0%, var(--amber-500) 100%);
    box-shadow: var(--shadow-amber), 0 0 30px rgba(240, 165, 0, 0.3);
    transform: translateY(-2px);
  }
  
  button.primary:active {
    transform: translateY(0);
    box-shadow: var(--shadow-sm);
  }
  
  button.secondary {
    flex: 0 0 auto;
    background: var(--panel-surface);
    color: var(--text-secondary);
    border: 1px solid var(--panel-border);
    position: relative;
  }
  
  button.secondary:hover {
    border-color: var(--panel-border-hover);
    color: var(--text-primary);
    background: var(--panel-elevated);
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }
  
  button.secondary:active {
    transform: scale(0.97);
  }
  
  .quick-actions {
    margin: 12px 0 0 0;
  }

  .quick-action-btn {
    width: 100%;
    padding: 12px 16px;
    background: transparent;
    border: 1px dashed var(--text-muted) !important;
    color: var(--text-secondary);
    border-radius: var(--radius-md);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out);
    font-family: var(--font-body);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    -webkit-tap-highlight-color: transparent;
  }
  
  .quick-action-btn:hover {
    border-color: var(--amber-500) !important;
    border-style: solid !important;
    color: var(--amber-400);
    background: var(--amber-glow);
  }
  
  .quick-action-btn:active {
    transform: scale(0.98);
  }

  /* Route status */
  #route-status {
    margin-top: 16px;
  }

  .status-line {
    margin: 0 0 12px 0;
    font-size: 13px;
    color: var(--text-secondary);
    font-family: var(--font-body);
  }

  /* Turn-by-turn directions list */
  #directions-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  #directions-list:empty {
    display: none;
  }

  /* Steps are injected as <li> via innerHTML — use :global so Astro scoped styles apply */
  
  /* Empty state (JS-injected content) */
  #empty-state {
    color: var(--text-muted);
    font-size: 13px;
    padding: var(--space-4) 0;
  }
  
  /* Scrollbar styling */
  #nav-panel::-webkit-scrollbar {
    width: 4px;
  }
  
  #nav-panel::-webkit-scrollbar-track {
    background: transparent;
  }
  
  #nav-panel::-webkit-scrollbar-thumb {
    background: var(--panel-elevated);
    border-radius: var(--radius-full);
  }
  
  #nav-panel::-webkit-scrollbar-thumb:hover {
    background: var(--text-muted);
  }
  
  /* Remove excessive responsive rules - now mobile-first */
</style>

<!-- Direction step styles, favorites, recent, search, and schedule styles must be global
     because elements are injected via JS/innerHTML and Astro scoped styles don't apply -->
<style is:global>
  .direction-step {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    background: var(--panel-surface);
    border: 1px solid var(--panel-border);
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--text-secondary);
    transition: background var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out),
                color var(--duration-fast) var(--ease-out);
  }

  .direction-step.active {
    background: var(--panel-elevated);
    border-color: var(--amber-500);
    color: var(--text-primary);
  }

  .direction-step.completed {
    opacity: 0.45;
  }

  .direction-step-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    font-family: var(--font-mono);
  }

  .direction-step-icon.start {
    background: #4CAF50;
    color: white;
  }

  .direction-step-icon.end {
    background: #f44336;
    color: white;
  }

  .direction-step-icon.stair {
    background: var(--stair-color);
    color: white;
