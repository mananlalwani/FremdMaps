<div id="onboarding-overlay" aria-modal="true" role="dialog" aria-label="Welcome to Fremd Maps">
  <div id="onboarding-card">
    <div class="ob-card-inner">
      <p class="ob-kicker">Welcome to Fremd Maps</p>
      <h1 class="ob-headline">Find a room. Get there.</h1>

      <p class="ob-copy">
        Search by room number or name. We’ll map the route and handle floor changes for you.
      </p>

      <button id="onboarding-dismiss" class="ob-btn">
        Get started
        <svg class="ob-arrow" viewBox="0 0 16 16" fill="none">
          <path
            d="M3 8h10M9 4l4 4-4 4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  #onboarding-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: max(24px, env(safe-area-inset-top)) 24px max(24px, env(safe-area-inset-bottom));
    overflow-y: auto;
    background: rgba(10, 10, 16, 0.72);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    animation: overlay-in 400ms var(--ease-out) both;
  }

  #onboarding-overlay.dismissing {
    animation: overlay-out 200ms var(--ease-out) both;
  }

  @keyframes overlay-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes overlay-out {
    from {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
    to {
      opacity: 0;
      transform: translateY(-12px);
      filter: blur(6px);
    }
  }

  #onboarding-card {
    width: 100%;
    max-width: 356px;
    margin: auto;
    background: var(--panel-bg);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 24px;
    box-shadow:
      0 20px 48px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.04);
    overflow: hidden;
    animation: card-in 400ms var(--ease-out) both;
    animation-delay: 60ms;
  }

  @keyframes card-in {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.97);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  .ob-card-inner {
    position: relative;
    padding: 32px;
    background:
      radial-gradient(ellipse 140% 80% at 50% -20%, rgba(240, 165, 0, 0.06) 0%, transparent 70%),
      radial-gradient(ellipse 60% 50% at 80% 100%, rgba(240, 165, 0, 0.04) 0%, transparent 60%);
  }

  .ob-kicker {
    margin: 0 0 14px;
    color: var(--amber-500);
    font: 600 13px var(--font-body);
    letter-spacing: 0;
    animation: fade-up 350ms var(--ease-out) both;
    animation-delay: 100ms;
  }

  .ob-headline {
    margin: 0 0 12px;
    font-family: var(--font-display);
    font-size: 34px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -1.1px;
    line-height: 1.15;
    text-wrap: balance;
    animation: fade-up 350ms var(--ease-out) both;
    animation-delay: 160ms;
  }

  .ob-copy {
    margin: 0 0 28px;
    font-size: 14px;
    color: var(--text-secondary);
    font-family: var(--font-body);
    line-height: 1.5;
    text-wrap: pretty;
    animation: fade-up 350ms var(--ease-out) both;
    animation-delay: 220ms;
  }

  .ob-btn {
    width: 100%;
    padding: 14px 18px;
    background: linear-gradient(135deg, var(--amber-500) 0%, var(--amber-600) 100%);
    color: var(--panel-bg);
    border: none;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 600;
    font-family: var(--font-body);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition:
      box-shadow var(--duration-normal) var(--ease-out),
      transform var(--duration-normal) var(--ease-out);
    box-shadow: 0 4px 20px rgba(240, 165, 0, 0.25);
    -webkit-tap-highlight-color: transparent;
    animation: fade-up 350ms var(--ease-out) both;
    animation-delay: 280ms;
  }

  .ob-btn:hover {
    box-shadow: 0 4px 28px rgba(240, 165, 0, 0.4);
    transform: translateY(-1px);
  }

  .ob-btn:active {
    transform: translateY(0) scale(0.96);
    box-shadow: 0 2px 8px rgba(240, 165, 0, 0.2);
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ob-arrow {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    transition: transform 200ms var(--ease-out);
  }

  .ob-btn:hover .ob-arrow {
    transform: translateX(3px);
  }

  @media (max-width: 480px) {
    .ob-card-inner {
      padding: 24px;
    }

    .ob-headline {
      font-size: 30px;
    }
  }
</style>

<script>
  const STORAGE_KEY = 'wayfinder_onboarded'

  const overlay = document.getElementById('onboarding-overlay')
  const dismissBtn = document.getElementById('onboarding-dismiss') as HTMLButtonElement | null

  if (localStorage.getItem(STORAGE_KEY)) {
    overlay?.remove()
  } else {
    dismissBtn?.focus()
  }

  overlay?.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab' || !overlay.isConnected) return
    e.preventDefault()
    dismissBtn?.focus()
  })

  dismissBtn?.addEventListener('click', () => {
    localStorage.setItem(STORAGE_KEY, '1')
    overlay?.classList.add('dismissing')
    overlay?.addEventListener('animationend', () => overlay.remove(), { once: true })
  })

  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) dismissBtn?.click()
  })

  const escapeController = new AbortController()
  document.addEventListener(
    'keydown',
    (e) => {
      if (e.key === 'Escape' && overlay?.isConnected) dismissBtn?.click()
    },
    { signal: escapeController.signal }
  )

  const observer = new MutationObserver(() => {
    if (!overlay?.isConnected) {
      escapeController.abort()
      observer.disconnect()
    }
  })
  if (overlay) observer.observe(overlay, { childList: false, subtree: false })
</script>
