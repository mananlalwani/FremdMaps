---
import '../styles/onboarding-overlay.css'
---

<div id="onboarding-overlay" aria-modal="true" role="dialog" aria-label="Welcome to Fremd Maps">
  <div id="onboarding-card">
    <div class="ob-card-inner">
      <p class="ob-kicker">Welcome to Fremd Maps</p>
      <h1 class="ob-headline">Find a room. Get there.</h1>

      <p class="ob-copy">
        Search by room number or name. We’ll map the route and handle floor changes for you.
      </p>

      <button id="onboarding-dismiss" class="ob-btn">
        Get started
        <svg class="ob-arrow" viewBox="0 0 16 16" fill="none">
          <path
            d="M3 8h10M9 4l4 4-4 4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>
    </div>
  </div>
</div>
