<div id="onboarding-overlay" aria-modal="true" role="dialog" aria-label="Welcome to Fremd Maps">
  <div id="onboarding-card">
    <div class="ob-card-inner">
      <div class="ob-brand">
        <svg class="ob-compass" viewBox="0 0 40 40" fill="none">
          <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="1.2" opacity="0.3"
          ></circle>
          <circle cx="20" cy="20" r="12" stroke="currentColor" stroke-width="0.8" opacity="0.15"
          ></circle>
          <polygon points="20,8 23,17 20,20 17,17" fill="currentColor" opacity="0.5"></polygon>
          <polygon points="20,32 17,23 20,20 23,23" fill="currentColor" opacity="0.9"></polygon>
        </svg>
      </div>

      <h1 class="ob-headline">Find any room<br /> at Fremd</h1>

      <div class="ob-features">
        <div class="ob-feature">
          <span class="ob-feature-dot"></span>
          <span class="ob-feature-text">Search by room number or name</span>
        </div>
        <div class="ob-feature">
          <span class="ob-feature-dot"></span>
          <span class="ob-feature-text">Turn-by-turn directions on the map</span>
        </div>
        <div class="ob-feature">
          <span class="ob-feature-dot"></span>
          <span class="ob-feature-text">Multi-floor routes handled automatically</span>
        </div>
      </div>

      <button id="onboarding-dismiss" class="ob-btn">
        Get started
        <svg class="ob-arrow" viewBox="0 0 16 16" fill="none">
          <path
            d="M3 8h10M9 4l4 4-4 4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  #onboarding-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: max(24px, env(safe-area-inset-top)) 24px max(24px, env(safe-area-inset-bottom));
    overflow-y: auto;
    background: rgba(10, 10, 16, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    animation: overlay-in 400ms var(--ease-out) both;
  }

  #onboarding-overlay.dismissing {
    animation: overlay-out 200ms var(--ease-out) both;
  }

  @keyframes overlay-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes overlay-out {
    from {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
    to {
      opacity: 0;
      transform: translateY(-12px);
      filter: blur(6px);
    }
  }

  #onboarding-card {
    width: 100%;
    max-width: 380px;
    margin: auto;
    background: var(--panel-bg);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 24px;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.7);
    overflow: hidden;
    animation: card-in 400ms var(--ease-out) both;
    animation-delay: 60ms;
  }

  @keyframes card-in {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.97);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  .ob-card-inner {
    position: relative;
    padding: 40px 32px 32px;
    background:
      radial-gradient(ellipse 140% 80% at 50% -20%, rgba(240, 165, 0, 0.06) 0%, transparent 70%),
      radial-gradient(ellipse 60% 50% at 80% 100%, rgba(240, 165, 0, 0.04) 0%, transparent 60%);
  }

  .ob-brand {
    margin-bottom: 28px;
  }

  .ob-compass {
    width: 32px;
    height: 32px;
    color: var(--amber-500);
  }

  .ob-headline {
    margin: 0 0 32px;
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: -0.5px;
    line-height: 1.15;
    text-wrap: balance;
  }

  .ob-features {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 36px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .ob-feature {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ob-feature-dot {
    flex-shrink: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--amber-500);
    opacity: 0.5;
  }

  .ob-feature-text {
    font-size: 14px;
    color: var(--text-secondary);
    font-family: var(--font-body);
    line-height: 1.4;
  }

  .ob-btn {
    width: 100%;
    padding: 14px 18px;
    background: linear-gradient(135deg, var(--amber-500) 0%, var(--amber-600) 100%);
    color: var(--panel-bg);
    border: none;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 600;
    font-family: var(--font-body);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition:
      box-shadow 200ms,
      transform 200ms;
    box-shadow: 0 4px 20px rgba(240, 165, 0, 0.25);
    -webkit-tap-highlight-color: transparent;
    animation: fade-up 350ms var(--ease-out) both;
    animation-delay: 160ms;
  }

  .ob-btn:hover {
    box-shadow: 0 4px 28px rgba(240, 165, 0, 0.4);
    transform: translateY(-1px);
  }

  .ob-btn:active {
    transform: translateY(0) scale(0.96);
    box-shadow: 0 2px 8px rgba(240, 165, 0, 0.2);
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ob-arrow {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    transition: transform 200ms var(--ease-out);
  }

  .ob-btn:hover .ob-arrow {
    transform: translateX(3px);
  }

  @media (max-width: 480px) {
    .ob-card-inner {
      padding: 32px 24px 28px;
    }

    .ob-headline {
      font-size: 30px;
    }
  }
</style>

<script>
  const STORAGE_KEY = 'wayfinder_onboarded'

  const overlay = document.getElementById('onboarding-overlay')
  const dismissBtn = document.getElementById('onboarding-dismiss') as HTMLButtonElement | null

  if (localStorage.getItem(STORAGE_KEY)) {
    overlay?.remove()
  } else {
    dismissBtn?.focus()
  }

  overlay?.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab' || !overlay.isConnected) return
    e.preventDefault()
    dismissBtn?.focus()
  })

  dismissBtn?.addEventListener('click', () => {
    localStorage.setItem(STORAGE_KEY, '1')
    overlay?.classList.add('dismissing')
    overlay?.addEventListener('animationend', () => overlay.remove(), { once: true })
  })

  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) dismissBtn?.click()
  })

  const escapeController = new AbortController()
  document.addEventListener(
    'keydown',
    (e) => {
      if (e.key === 'Escape' && overlay?.isConnected) dismissBtn?.click()
    },
    { signal: escapeController.signal }
  )

  const observer = new MutationObserver(() => {
    if (!overlay?.isConnected) {
      escapeController.abort()
      observer.disconnect()
    }
  })
  if (overlay) observer.observe(overlay, { childList: false, subtree: false })
</script>
